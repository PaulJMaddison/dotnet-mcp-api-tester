{
  "openapi": "3.0.1",
  "info": {
    "title": "Fixture API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://fixtureapi:8080"
    }
  ],
  "paths": {
    "/v1/ping": {
      "get": {
        "operationId": "getPing",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/v1/widgets/{id}": {
      "get": {
        "operationId": "getWidgetById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/v1/widgets": {
      "post": {
        "operationId": "createWidget",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  }
}
