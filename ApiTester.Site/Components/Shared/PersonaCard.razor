<div class="card h-100 border-0 shadow-sm">
    <div class="card-body">
        <h3 class="h5">@Title</h3>
        <p class="mb-2">@Outcome</p>
        <p class="text-muted mb-0">@Proof</p>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Outcome { get; set; } = string.Empty;
    [Parameter] public string Proof { get; set; } = string.Empty;
}
