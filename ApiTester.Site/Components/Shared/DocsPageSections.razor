@using ApiTester.Site.Content

@foreach (var docSection in Page.Sections)
{
    <section id="@docSection.Id" class="doc-section mb-4">
        <h2 class="h5 fw-bold">@docSection.Heading</h2>
        <p>@docSection.Body</p>
        @if (docSection.Bullets.Any())
        {
            <ul class="doc-list">
                @foreach (var bullet in docSection.Bullets)
                {
                    <li class="mb-2">@bullet</li>
                }
            </ul>
        }
        @if (docSection.Callouts.Any())
        {
            <div class="row g-3 mt-3">
                @foreach (var callout in docSection.Callouts)
                {
                    <div class="col-md-6">
                        <div class="p-3 bg-light border rounded-3 h-100">
                            <h3 class="h6 fw-bold">@callout.Title</h3>
                            <p class="small text-muted mb-0">@callout.Body</p>
                        </div>
                    </div>
                }
            </div>
        }
        @if (docSection.CodeSnippet is not null)
        {
            <div class="mt-3">
                <CodeBlock Title="@docSection.CodeSnippet.Title"
                           Description="@docSection.CodeSnippet.Description"
                           Language="@docSection.CodeSnippet.Language"
                           Code="@docSection.CodeSnippet.Code" />
            </div>
        }
    </section>
}

@code {
    [Parameter] public DocPage Page { get; set; } = null!;
}
