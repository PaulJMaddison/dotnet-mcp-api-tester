@page "/app/account"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IHttpContextAccessor HttpContextAccessor
@inject ApiTester.Site.Services.ITenantBootstrapper TenantBootstrapper

<PageTitle>Account</PageTitle>

<div class="app-page">
    <SectionContent SectionName="AppBreadcrumbs">
        <AppBreadcrumbs Items="@Breadcrumbs" />
    </SectionContent>

    <div class="app-page-header">
        <div>
            <h1 class="h3 mb-1" data-testid="account-title">Account</h1>
            <p class="text-secondary mb-0">Identity and tenant membership for your workspace.</p>
        </div>
    </div>

    @if (_account is null)
    {
        <div class="app-card app-state">
            <h2 class="h6">Account not available</h2>
            <p class="text-secondary mb-0">Unable to resolve account details from claims.</p>
        </div>
    }
    else
    {
        <div class="app-card" data-testid="account-card">
            <dl class="row mb-0">
                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@_account.Email</dd>

                <dt class="col-sm-3">Display name</dt>
                <dd class="col-sm-9">@_account.DisplayName</dd>

                <dt class="col-sm-3">Tenant</dt>
                <dd class="col-sm-9">@_account.TenantName</dd>

                <dt class="col-sm-3">Role</dt>
                <dd class="col-sm-9">@_account.Role</dd>
            </dl>
            <div class="mt-3">
                <NavLink href="/app/api-keys" class="btn btn-outline-secondary">API keys</NavLink>
            </div>
        </div>
    }
</div>

@code {
    private readonly IReadOnlyList<BreadcrumbItem> Breadcrumbs = new List<BreadcrumbItem>
    {
        new("Account", "/app/account")
    };

    private AccountSummary? _account;

    protected override async Task OnInitializedAsync()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        if (user is null)
        {
            return;
        }

        await TenantBootstrapper.EnsureUserTenantMembershipAsync(user, CancellationToken.None);
        _account = await TenantBootstrapper.GetAccountSummaryAsync(user, CancellationToken.None);
    }
}
