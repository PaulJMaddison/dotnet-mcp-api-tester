@page "/app/tokens"
@inject ApiTester.Site.Services.IApiTesterWebClient ApiClient
@inject NavigationManager NavigationManager

<PageTitle>API Tokens · ApiTester</PageTitle>

<SectionContent SectionName="AppBreadcrumbs">
    <AppBreadcrumbs Items="_breadcrumbs" />
</SectionContent>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h3 mb-1">API tokens</h1>
        <p class="text-secondary mb-0">Create and rotate tenant-scoped tokens. Plaintext is shown once.</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}

@if (!string.IsNullOrWhiteSpace(_createdToken))
{
    <div class="alert alert-warning">
        <strong>Copy now:</strong> this token will not be shown again.
        <pre class="mt-2 mb-0"><code>@_createdToken</code></pre>
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        <h2 class="h5">Create token</h2>
        <div class="row g-2">
            <div class="col-md-4"><input class="form-control" @bind="_name" placeholder="Name" /></div>
            <div class="col-md-6"><input class="form-control" @bind="_scopes" placeholder="Scopes (comma-separated)" /></div>
            <div class="col-md-2 d-grid"><button class="btn btn-primary" @onclick="CreateAsync">Create</button></div>
        </div>
    </div>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th><th>Prefix</th><th>Scopes</th><th>Last used</th><th>Status</th><th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var t in _tokens)
    {
        <tr>
            <td>@t.Name</td>
            <td><code>@t.Prefix</code></td>
            <td>@string.Join(", ", t.Scopes)</td>
            <td>@(t.LastUsedUtc?.ToString("u") ?? "Never")</td>
            <td>@(t.RevokedUtc.HasValue ? "Revoked" : "Active")</td>
            <td>
                @if (!t.RevokedUtc.HasValue)
                {
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RevokeAsync(t.KeyId)">Revoke</button>
                }
            </td>
        </tr>
    }
    </tbody>
</table>

@code {
    private readonly IReadOnlyList<BreadcrumbItem> _breadcrumbs =
    [
        new("Workspace", "/app/projects"),
        new("Tokens", "/app/tokens")
    ];

    private List<ApiTester.Site.Models.ApiTokenDto> _tokens = [];
    private string _name = string.Empty;
    private string _scopes = "projects:read";
    private string? _createdToken;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var result = await ApiClient.GetTokensAsync(CancellationToken.None);
        if (!result.IsSuccess)
        {
            _error = result.Error?.Message;
            return;
        }

        _tokens = result.Data!.Keys.ToList();
    }

    private async Task CreateAsync()
    {
        _error = null;
        var scopes = _scopes.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).ToList();
        var result = await ApiClient.CreateTokenAsync(new ApiTester.Site.Models.ApiTokenCreateRequest(_name, scopes, null), CancellationToken.None);
        if (!result.IsSuccess)
        {
            _error = result.Error?.Message;
            return;
        }

        _createdToken = result.Data!.Token;
        _name = string.Empty;
        await LoadAsync();
    }

    private async Task RevokeAsync(Guid id)
    {
        var result = await ApiClient.RevokeTokenAsync(id, CancellationToken.None);
        if (!result.IsSuccess)
        {
            _error = result.Error?.Message;
            return;
        }

        await LoadAsync();
    }
}
