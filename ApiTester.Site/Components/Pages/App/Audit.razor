@page "/app/audit"
@inject IApiTesterWebClient ApiClient
@inject NavigationManager NavigationManager

<PageTitle>Audit log</PageTitle>

<div class="app-page">
    <SectionContent SectionName="AppBreadcrumbs">
        <AppBreadcrumbs Items="@Breadcrumbs" />
    </SectionContent>

    <div class="app-page-header">
        <div>
            <h1 class="h3 mb-1">Audit log</h1>
            <p class="text-secondary mb-0">Review tenant audit events for exports, runs, and configuration activity.</p>
        </div>
    </div>

    <div class="app-card app-filter-bar">
        <div class="d-flex align-items-center gap-2 text-uppercase small text-secondary">
            <img src="/assets/runs/run-filter.svg" alt="" aria-hidden="true" width="16" height="16" />
            <span>Filters</span>
        </div>
        <form class="row g-3 align-items-end mt-1" method="get" action="/app/audit">
            <div class="col-12 col-md-3">
                <label class="form-label" for="audit-action">Action</label>
                <input class="form-control" id="audit-action" name="action" value="@Action" placeholder="export.generated" />
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label" for="audit-from">From (UTC)</label>
                <input class="form-control" id="audit-from" name="from" value="@From" placeholder="2026-01-01T00:00:00Z" />
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label" for="audit-to">To (UTC)</label>
                <input class="form-control" id="audit-to" name="to" value="@To" placeholder="2026-01-31T23:59:59Z" />
            </div>
            <div class="col-12 col-md-1">
                <label class="form-label" for="audit-take">Take</label>
                <input class="form-control" id="audit-take" name="take" value="@Take" placeholder="50" />
            </div>
            <div class="col-12 col-md-2">
                <button class="btn btn-primary w-100" type="submit">Apply</button>
            </div>
        </form>
    </div>

    @if (_isGated)
    {
        <div class="app-card app-state app-state-warning">
            <div>
                <h2 class="h5 mb-2">Audit log requires Team</h2>
                <p class="text-secondary mb-3">Audit visibility is reserved for Team workspaces so compliance reviewers can trace who exported or changed what and when.</p>
                <a class="btn btn-primary" href="/pricing">Upgrade to Team</a>
            </div>
        </div>
    }
    else if (_isLoading)
    {
        <div class="app-card app-state">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <span class="ms-2">Loading audit events...</span>
        </div>
    }
    else if (_response?.Error is not null)
    {
        <div class="app-card app-state app-state-error">
            <h2 class="h6">Unable to load audit events</h2>
            <p class="text-secondary">@_response.Error.Message</p>
            @if (!string.IsNullOrWhiteSpace(_response.Error.Details))
            {
                <details>
                    <summary>View error details</summary>
                    <pre class="mb-0">@_response.Error.Details</pre>
                </details>
            }
        </div>
    }
    else if (_response?.Data is null || _response.Data.Events.Count == 0)
    {
        <div class="app-card app-state">
            <h2 class="h6">No audit events found</h2>
            <p class="text-secondary mb-0">Try broadening filters or generating activity in ApiTester Web.</p>
        </div>
    }
    else
    {
        <div class="app-card">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th scope="col">When (UTC)</th>
                            <th scope="col">Action</th>
                            <th scope="col">Actor</th>
                            <th scope="col">Target</th>
                            <th scope="col">Metadata</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var evt in _response.Data.Events)
                        {
                            <tr>
                                <td>@evt.OccurredUtc.ToString("u")</td>
                                <td><code>@evt.Action</code></td>
                                <td>@(string.IsNullOrWhiteSpace(evt.Actor) ? "system" : evt.Actor)</td>
                                <td>
                                    <div class="fw-semibold">@evt.TargetType</div>
                                    <div class="text-secondary small">@evt.TargetId</div>
                                </td>
                                <td>
                                    @if (string.IsNullOrWhiteSpace(evt.MetadataJson))
                                    {
                                        <span class="text-secondary">-</span>
                                    }
                                    else
                                    {
                                        <details>
                                            <summary>View metadata</summary>
                                            <pre class="mb-0">@evt.MetadataJson</pre>
                                        </details>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery] public int? Take { get; set; }
    [SupplyParameterFromQuery] public string? Action { get; set; }
    [SupplyParameterFromQuery] public string? From { get; set; }
    [SupplyParameterFromQuery] public string? To { get; set; }

    private ApiResult<AuditListResponse>? _response;
    private bool _isLoading = true;
    private bool _isGated;

    private IReadOnlyList<BreadcrumbItem> Breadcrumbs => new List<BreadcrumbItem>
    {
        new("Audit log", "/app/audit")
    };

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _isGated = false;

        var plan = await ApiClient.GetBillingPlanAsync(CancellationToken.None);
        if (plan.Error?.StatusCode == 401)
        {
            NavigationManager.NavigateTo("/app/sign-in");
            return;
        }

        if (plan.Data is not null && !plan.Data.AuditExportEnabled)
        {
            _isLoading = false;
            _isGated = true;
            return;
        }

        _response = await ApiClient.GetAuditEventsAsync(Take, Action, From, To, CancellationToken.None);
        if (_response?.Error?.StatusCode == 401)
        {
            NavigationManager.NavigateTo("/app/sign-in");
            return;
        }

        if (_response?.Error?.StatusCode == 402 || _response?.Error?.StatusCode == 403)
        {
            _isGated = true;
        }

        _isLoading = false;
    }
}
