@page "/app/runs"
@inject IApiTesterWebClient ApiClient
@inject NavigationManager NavigationManager

<PageTitle>Runs</PageTitle>

<div class="app-page">
    <SectionContent SectionName="AppBreadcrumbs">
        <AppBreadcrumbs Items="@Breadcrumbs" />
    </SectionContent>

    <div class="app-page-header">
        <div>
            <h1 class="h3 mb-1">Runs</h1>
            <p class="text-secondary mb-0">Search and review recent test runs across projects.</p>
        </div>
    </div>

    <div class="app-card app-filter-bar">
        <div class="text-uppercase small text-secondary">Filters</div>
        <form class="row g-3 align-items-end mt-1" method="get" action="/app/runs">
            <div class="col-12 col-md-4">
                <label class="form-label" for="runs-project-key">Project key</label>
                <input class="form-control" id="runs-project-key" name="projectKey" value="@ProjectKey" placeholder="project-key" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label" for="runs-operation-id">Operation ID</label>
                <input class="form-control" id="runs-operation-id" name="operationId" value="@OperationId" placeholder="Optional operation" />
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label" for="runs-take">Take</label>
                <input class="form-control" id="runs-take" name="take" value="@Take" placeholder="25" />
            </div>
            <div class="col-12 col-md-2">
                <button class="btn btn-primary w-100" type="submit">Apply</button>
            </div>
        </form>
        <div class="text-secondary small mt-2">Use <code>projectKey</code>, <code>operationId</code>, and <code>take</code> query params to refine results.</div>
    </div>

    @if (_isLoading)
    {
        <div class="app-card app-state">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <span class="ms-2">Loading runs...</span>
        </div>
    }
    else if (_response?.Error is not null)
    {
        <div class="app-card app-state app-state-error">
            <h2 class="h6">Unable to load runs</h2>
            <p class="text-secondary">@_response.Error.Message</p>
            @if (!string.IsNullOrWhiteSpace(_response.Error.Details))
            {
                <details>
                    <summary>View error details</summary>
                    <pre class="mb-0">@_response.Error.Details</pre>
                </details>
            }
        </div>
    }
    else if (_response?.Data is null || _response.Data.Runs.Count == 0)
    {
        <div class="app-card app-state">
            <h2 class="h6">No runs found</h2>
            <p class="text-secondary mb-0">Adjust the filters or trigger a run in ApiTester Web.</p>
        </div>
    }
    else
    {
        <div class="app-card">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th scope="col">Run ID</th>
                            <th scope="col">Project key</th>
                            <th scope="col">Operation ID</th>
                            <th scope="col">Started</th>
                            <th scope="col">Completed</th>
                            <th scope="col">Total cases</th>
                            <th scope="col">Passed</th>
                            <th scope="col">Expected blocked</th>
                            <th scope="col">Flaky</th>
                            <th scope="col">Real fail</th>
                            <th scope="col">Total duration (ms)</th>
                            <th scope="col">Classified pass</th>
                            <th scope="col">Classified fail</th>
                            <th scope="col">Classified blocked expected</th>
                            <th scope="col">Classified blocked unexpected</th>
                            <th scope="col">Classified flaky external</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var run in _response.Data.Runs)
                        {
                            <tr>
                                <td>
                                    <NavLink href="@($"/app/runs/{run.RunId}")">@run.RunId.ToString("N").Substring(0, 8)</NavLink>
                                    <div class="text-secondary small">@run.RunId</div>
                                </td>
                                <td>@run.ProjectKey</td>
                                <td>@run.OperationId</td>
                                <td>@run.StartedUtc.ToString("g")</td>
                                <td>@run.CompletedUtc.ToString("g")</td>
                                <td>@run.Snapshot.TotalCases</td>
                                <td>@run.Snapshot.Passed</td>
                                <td>@run.Snapshot.ExpectedBlocked</td>
                                <td>@run.Snapshot.Flaky</td>
                                <td>@run.Snapshot.RealFail</td>
                                <td>@run.Snapshot.TotalDurationMs</td>
                                <td>@run.Snapshot.ClassificationSummary.Pass</td>
                                <td>@run.Snapshot.ClassificationSummary.Fail</td>
                                <td>@run.Snapshot.ClassificationSummary.BlockedExpected</td>
                                <td>@run.Snapshot.ClassificationSummary.BlockedUnexpected</td>
                                <td>@run.Snapshot.ClassificationSummary.FlakyExternal</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery] public string? ProjectKey { get; set; }
    [SupplyParameterFromQuery] public string? OperationId { get; set; }
    [SupplyParameterFromQuery] public int? Take { get; set; }

    private ApiResult<RunSummaryResponse>? _response;
    private bool _isLoading = true;

    private IReadOnlyList<BreadcrumbItem> Breadcrumbs => new List<BreadcrumbItem>
    {
        new("Runs", "/app/runs")
    };

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        if (string.IsNullOrWhiteSpace(ProjectKey))
        {
            _response = ApiResult<RunSummaryResponse>.Failure("Project key is required to load runs.", null);
            _isLoading = false;
            return;
        }

        _response = await ApiClient.GetRunsAsync(ProjectKey, OperationId, Take, CancellationToken.None);
        if (_response?.Error?.StatusCode == 401)
        {
            NavigationManager.NavigateTo("/app/sign-in");
            return;
        }
        _isLoading = false;
    }
}
