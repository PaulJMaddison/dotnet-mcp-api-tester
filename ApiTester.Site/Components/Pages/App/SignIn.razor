@page "/app/sign-in"
@using System.ComponentModel.DataAnnotations
@inject ApiTester.Site.Services.IApiKeySession ApiKeySession
@inject NavigationManager NavigationManager

<PageTitle>Sign in</PageTitle>

<section class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-6">
            <div class="app-card">
                <h1 class="h3 mb-3">Sign in with your API key</h1>
                <p class="text-secondary">
                    Enter your ApiTester API key to unlock your workspace. The key is stored in your session only and
                    never shown or persisted in the UI.
                </p>
                <EditForm Model="@_model" OnValidSubmit="@HandleSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-danger" />
                    <div class="mb-3">
                        <label class="form-label" for="api-key">API key</label>
                        <InputText id="api-key" class="form-control" type="password" autocomplete="off" @bind-Value="_model.ApiKey" />
                    </div>
                    <button type="submit" class="btn btn-primary">Save key</button>
                </EditForm>
            </div>
        </div>
    </div>
</section>

@code {
    private readonly ApiKeyInputModel _model = new();

    private void HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(_model.ApiKey))
        {
            return;
        }

        ApiKeySession.SetApiKey(_model.ApiKey);
        _model.Clear();
        NavigationManager.NavigateTo("/app/onboarding");
    }

    private sealed class ApiKeyInputModel
    {
        [Required]
        public string ApiKey { get; set; } = string.Empty;

        public void Clear()
        {
            ApiKey = string.Empty;
        }
    }
}
