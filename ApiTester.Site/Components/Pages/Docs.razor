@page "/docs"

@code {
    private DeveloperDocsContent Content { get; } = MarketingContent.Current.DeveloperDocs;
    private PageMetadata Metadata => Content.Metadata;
}

<PageTitle>@Metadata.Title</PageTitle>
<HeadContent>
    <meta name="description" content="@Metadata.Description" />
    <meta property="og:title" content="@Metadata.OgTitle" />
    <meta property="og:description" content="@Metadata.OgDescription" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@Metadata.CanonicalUrl" />
    <meta property="og:image" content="@Metadata.OgImage" />
    <meta property="og:image:alt" content="@Metadata.OgImageAlt" />
    <meta name="twitter:card" content="@MarketingContent.Current.Metadata.TwitterCard" />
    <meta name="twitter:title" content="@Metadata.OgTitle" />
    <meta name="twitter:description" content="@Metadata.OgDescription" />
    <meta name="twitter:image" content="@Metadata.OgImage" />
    <meta name="twitter:image:alt" content="@Metadata.OgImageAlt" />
    <link rel="canonical" href="@Metadata.CanonicalUrl" />
</HeadContent>

<section class="page-hero bg-light py-5">
    <div class="container">
        <h1 class="display-5 fw-bold">@Content.HeroTitle</h1>
        <p class="lead">@Content.HeroSubtitle</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-6">
                <h2 class="h4 fw-bold">@Content.QuickstartTitle</h2>
                <ol class="ps-3">
                    @foreach (var step in Content.QuickstartSteps)
                    {
                        <li class="mb-2">@step</li>
                    }
                </ol>
            </div>
            <div class="col-lg-6">
                <div class="diagram-placeholder">
                    <div class="placeholder-grid">@Content.WorkflowPlaceholder.Title</div>
                    <p class="mb-0">@Content.WorkflowPlaceholder.Description</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="bg-white py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-6">
                <h2 class="h4 fw-bold">@Content.McpTitle</h2>
                <ul class="list-unstyled">
                    @foreach (var highlight in Content.McpHighlights)
                    {
                        <li class="mb-2">@highlight</li>
                    }
                </ul>
            </div>
            <div class="col-lg-6">
                <h2 class="h4 fw-bold">@Content.EnvironmentTitle</h2>
                <ul class="list-unstyled">
                    @foreach (var step in Content.EnvironmentSteps)
                    {
                        <li class="mb-2">@step</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-6">
                <h2 class="h4 fw-bold">@Content.CiTitle</h2>
                <ol class="ps-3">
                    @foreach (var step in Content.CiSteps)
                    {
                        <li class="mb-2">@step</li>
                    }
                </ol>
            </div>
            <div class="col-lg-6">
                <div class="d-flex flex-column gap-4">
                    @foreach (var snippet in Content.CodeSnippets)
                    {
                        <CodeBlock Title="@snippet.Title"
                                   Description="@snippet.Description"
                                   Language="@snippet.Language"
                                   Code="@snippet.Code" />
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<section class="cta-section text-white py-5">
    <div class="container text-center">
        <h2 class="fw-bold">@Content.CtaTitle</h2>
        <p class="lead">@Content.CtaSubtitle</p>
        <a class="btn btn-light btn-lg" href="@Content.CtaLink">@Content.CtaLabel</a>
    </div>
</section>
