@page "/docs"
@using ApiTester.Site.Content

@code {
    private DeveloperDocsContent Marketing => MarketingContent.Current.DeveloperDocs;
    private PageMetadata Metadata => Marketing.Metadata;
    private DocsLibrary Docs => DocsContent.Current;
}

<PageTitle>@Metadata.Title</PageTitle>
<HeadContent>
    <meta name="description" content="@Metadata.Description" />
    <meta property="og:title" content="@Metadata.OgTitle" />
    <meta property="og:description" content="@Metadata.OgDescription" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@Metadata.CanonicalUrl" />
    <meta property="og:image" content="@Metadata.OgImage" />
    <meta property="og:image:alt" content="@Metadata.OgImageAlt" />
    <meta name="twitter:card" content="@MarketingContent.Current.Metadata.TwitterCard" />
    <meta name="twitter:title" content="@Metadata.OgTitle" />
    <meta name="twitter:description" content="@Metadata.OgDescription" />
    <meta name="twitter:image" content="@Metadata.OgImage" />
    <meta name="twitter:image:alt" content="@Metadata.OgImageAlt" />
    <link rel="canonical" href="@Metadata.CanonicalUrl" />
</HeadContent>

<DocsShell Title="@Docs.Landing.HeroTitle" Subtitle="@Docs.Landing.HeroSubtitle" ActiveUrl="/docs">
    <section class="doc-section mb-4">
        <h2 class="h5 fw-bold">Why ApiTester docs?</h2>
        <ul class="doc-list">
            @foreach (var highlight in Docs.Landing.Highlights)
            {
                <li class="mb-2">@highlight</li>
            }
        </ul>
    </section>

    @foreach (var group in Docs.Landing.NavGroups)
    {
        <section class="doc-section mb-4">
            <h2 class="h5 fw-bold">@group.Title</h2>
            <div class="row g-3">
                @foreach (var item in group.Items)
                {
                    <div class="col-md-6">
                        <div class="h-100 border rounded-3 p-3 bg-white">
                            <h3 class="h6 fw-bold mb-2">@item.Title</h3>
                            <p class="small text-muted">@item.Summary</p>
                            <a class="text-decoration-none fw-semibold" href="@item.Url">Read guide →</a>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    <section class="doc-section">
        <h2 class="h5 fw-bold">@Docs.Landing.SupportTitle</h2>
        <p class="mb-3">@Docs.Landing.SupportSubtitle</p>
        <a class="btn btn-primary" href="/contact">Talk to the team</a>
    </section>
</DocsShell>
