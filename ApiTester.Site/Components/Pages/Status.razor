@page "/status"

<section class="page-hero bg-light py-5">
    <div class="container">
        <h1 class="display-5 fw-bold">System status</h1>
        <p class="lead">The status page is coming soon. We will publish real-time uptime, incident updates, and maintenance windows here.</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-6">
                <h2 class="h4 fw-bold">What to expect</h2>
                <p>When live, this page will include service health, component history, and a public incident log for the last 12 months.</p>
            </div>
            <div class="col-lg-6">
                <h2 class="h4 fw-bold">Contact during an incident</h2>
                <p>If you need immediate assistance, email support@apitester.example.com or reach us through your customer success representative.</p>
            </div>
        </div>
    </div>
</section>
