@page "/features"

<section class="page-hero bg-light py-5">
    <div class="container">
        <h1 class="display-5 fw-bold">Features built for API-first teams</h1>
        <p class="lead">From scenario builders to release intelligence, ApiTester keeps every API contract observable and testable.</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="feature-card">
                    <h3 class="h5">Scenario Studio</h3>
                    <p>Compose multi-step API flows with validation blocks, data setup, and teardown, all inside a guided editor.</p>
                    <ul class="small text-muted">
                        <li>Reusable data fixtures</li>
                        <li>Inline response mapping</li>
                        <li>Audit-ready run logs</li>
                    </ul>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="feature-card">
                    <h3 class="h5">Live Monitoring</h3>
                    <p>Stay ahead of outages with automated canary tests tied to latency baselines and error rate thresholds.</p>
                    <ul class="small text-muted">
                        <li>Region-aware probes</li>
                        <li>Threshold alerting</li>
                        <li>Historical SLA trends</li>
                    </ul>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="feature-card">
                    <h3 class="h5">Contract Diffing</h3>
                    <p>Compare OpenAPI and GraphQL schema updates to highlight breaking changes before they ship.</p>
                    <ul class="small text-muted">
                        <li>Semantic change reports</li>
                        <li>Consumer impact checks</li>
                        <li>Approval workflows</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="row g-4 mt-3">
            <div class="col-lg-6">
                <img class="img-fluid rounded-4 shadow-sm visual-asset" src="images/hero-illustration.svg" alt="Illustration of an integrated run summary dashboard" loading="lazy" decoding="async" />
            </div>
            <div class="col-lg-6">
                <h2 class="fw-bold">Automation that feels human.</h2>
                <p>ApiTester pairs automated testing with human context so teams understand why a change matters. Share annotated runs, approval trails, and release notes with stakeholders.</p>
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="stat-card">
                            <h4 class="h6 text-uppercase">Collaboration</h4>
                            <p class="mb-0">Comment threads on every run keep QA, engineering, and product aligned.</p>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="stat-card">
                            <h4 class="h6 text-uppercase">Integrations</h4>
                            <p class="mb-0">Sync with GitHub, Azure DevOps, and CI pipelines without custom scripts.</p>
                        </div>
                    </div>
                </div>
                <a class="btn btn-primary mt-4" href="/pricing">See pricing options</a>
            </div>
        </div>
    </div>
</section>
