@page "/pricing"

@code {
    private PricingPageContent Content { get; } = MarketingContent.Current.Pricing;
    private ApiTester.Site.Content.PageMetadata Metadata => Content.Metadata;

    private static string GetPlanIcon(string planName) => planName switch
    {
        "Free" => "assets/pricing/plan-starter.svg",
        "Pro" => "assets/pricing/plan-growth.svg",
        "Team" => "assets/pricing/plan-enterprise.svg",
        _ => "assets/pricing/plan-starter.svg"
    };

    private static string GetPlanIconAlt(string planName) => $"{planName} tier icon";
}

<PageTitle>@Metadata.Title</PageTitle>
<HeadContent>
    <meta name="description" content="@Metadata.Description" />
    <meta property="og:title" content="@Metadata.OgTitle" />
    <meta property="og:description" content="@Metadata.OgDescription" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@Metadata.CanonicalUrl" />
    <meta property="og:image" content="@Metadata.OgImage" />
    <meta property="og:image:alt" content="@Metadata.OgImageAlt" />
    <meta name="twitter:card" content="@MarketingContent.Current.Metadata.TwitterCard" />
    <meta name="twitter:title" content="@Metadata.OgTitle" />
    <meta name="twitter:description" content="@Metadata.OgDescription" />
    <meta name="twitter:image" content="@Metadata.OgImage" />
    <meta name="twitter:image:alt" content="@Metadata.OgImageAlt" />
    <link rel="canonical" href="@Metadata.CanonicalUrl" />
</HeadContent>

<section class="page-hero bg-light py-5">
    <div class="container">
        <h1 class="display-5 fw-bold">@Content.HeroTitle</h1>
        <p class="lead">@Content.HeroSubtitle</p>
        <div class="d-flex flex-wrap gap-2 mt-4">
            <a class="btn btn-primary" href="@Content.PrimaryCtaLink">@Content.PrimaryCtaLabel</a>
            <a class="btn btn-outline-primary" href="@Content.SecondaryCtaLink">@Content.SecondaryCtaLabel</a>
        </div>
    </div>
</section>

<section class="py-5 pricing-pattern">
    <div class="container">
        <div class="row g-4">
            @foreach (var plan in Content.Plans)
            {
                <div class="col-lg-4">
                    <div class="card pricing-card h-100 @(plan.IsFeatured ? "featured" : string.Empty)">
                        <div class="card-body d-flex flex-column">
                            @if (!string.IsNullOrWhiteSpace(plan.Badge))
                            {
                                <div class="badge bg-primary">@plan.Badge</div>
                            }
                            <img class="pricing-tier-icon" src="@GetPlanIcon(plan.Name)" alt="@GetPlanIconAlt(plan.Name)" loading="lazy" decoding="async" />
                            <h3 class="h5 mt-3">@plan.Name</h3>
                            <p class="text-muted">@plan.Tagline</p>
                            <div class="display-6 fw-bold">@plan.Price <span class="fs-6 text-muted">@plan.PriceSuffix</span></div>
                            <ul class="mt-3">
                                @foreach (var highlight in plan.Highlights)
                                {
                                    <li>@highlight</li>
                                }
                            </ul>
                            <div class="mt-auto">
                                <a class="btn @(plan.IsFeatured ? "btn-primary" : "btn-outline-primary") w-100" href="@plan.CtaLink">@plan.CtaLabel</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section class="bg-white py-5">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-md-6">
                <h2 class="h4 fw-bold">@Content.ValuePropsTitle</h2>
                <ul class="list-unstyled">
                    @foreach (var value in Content.ValueProps)
                    {
                        <li class="mb-2">✅ @value</li>
                    }
                </ul>
            </div>
            <div class="col-md-6">
                <div class="diagram-panel">
                    <div class="diagram-grid">"Product capability overview"</div>
                    <p class="mb-0">@Content.ValuePropsPlaceholder.Description</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
            <div>
                <h2 class="h4 fw-bold">@Content.ComparisonTitle</h2>
                <p class="text-muted">@Content.ComparisonSubtitle</p>
            </div>
            <a class="btn btn-outline-primary" href="@Content.ComparisonCtaLink">@Content.ComparisonCtaLabel</a>
        </div>
        <PricingTable Plans="@Content.Plans" Features="@Content.FeatureMatrix" ComparisonHeader="@Content.ComparisonHeader" />
    </div>
</section>

<section class="bg-light py-5">
    <div class="container">
        <h2 class="h4 fw-bold">@Content.UseCasesTitle</h2>
        <p class="text-muted">@Content.UseCasesSubtitle</p>
        <FeatureGrid Items="@Content.UseCases"
                     TitleSelector="useCase => useCase.Title"
                     DescriptionSelector="useCase => useCase.Description"
                     ColumnClass="col-md-6 col-lg-3"
                     TitleClass="h6 fw-bold" />
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-4">
                <h2 class="h4 fw-bold">@Content.FaqTitle</h2>
                <p class="text-muted">@Content.FaqSubtitle</p>
            </div>
            <div class="col-lg-8">
                <div class="accordion" id="pricingFaq">
                    @for (var index = 0; index < Content.Faqs.Count; index++)
                    {
                        var faq = Content.Faqs[index];
                        var itemId = $"faq-{index}";
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="@itemId-heading">
                                <button class="accordion-button @(index == 0 ? string.Empty : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#@itemId" aria-expanded="@(index == 0)" aria-controls="@itemId">
                                    @faq.Question
                                </button>
                            </h2>
                            <div id="@itemId" class="accordion-collapse collapse @(index == 0 ? "show" : string.Empty)" aria-labelledby="@itemId-heading" data-bs-parent="#pricingFaq">
                                <div class="accordion-body">
                                    @faq.Answer
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
