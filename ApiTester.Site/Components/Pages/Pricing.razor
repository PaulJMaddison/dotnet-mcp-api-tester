@page "/pricing"

<section class="page-hero bg-light py-5">
    <div class="container">
        <h1 class="display-5 fw-bold">Pricing that scales with your team</h1>
        <p class="lead">Choose a plan that matches your release cadence, then expand as your API footprint grows.</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card pricing-card h-100">
                    <div class="card-body">
                        <h3 class="h5">Starter</h3>
                        <p class="text-muted">For early product teams validating their first APIs.</p>
                        <div class="display-6 fw-bold">$49<span class="fs-6 text-muted">/month</span></div>
                        <ul class="mt-3">
                            <li>Up to 5 projects</li>
                            <li>Basic monitoring</li>
                            <li>Email support</li>
                        </ul>
                        <a class="btn btn-outline-primary w-100" href="/contact">Get started</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card pricing-card featured h-100">
                    <div class="card-body">
                        <div class="badge bg-primary">Most Popular</div>
                        <h3 class="h5 mt-3">Growth</h3>
                        <p class="text-muted">For teams shipping weekly releases with shared QA workflows.</p>
                        <div class="display-6 fw-bold">$199<span class="fs-6 text-muted">/month</span></div>
                        <ul class="mt-3">
                            <li>Unlimited projects</li>
                            <li>Contract diffing</li>
                            <li>Slack + email alerts</li>
                        </ul>
                        <a class="btn btn-primary w-100" href="/contact">Book a demo</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card pricing-card h-100">
                    <div class="card-body">
                        <h3 class="h5">Enterprise</h3>
                        <p class="text-muted">For platform orgs with regulated workloads and multi-region APIs.</p>
                        <div class="display-6 fw-bold">Custom</div>
                        <ul class="mt-3">
                            <li>Dedicated environment</li>
                            <li>Advanced access controls</li>
                            <li>24/7 response team</li>
                        </ul>
                        <a class="btn btn-outline-primary w-100" href="/contact">Talk to sales</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="bg-white py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-6">
                <h2 class="h4 fw-bold">Every plan includes</h2>
                <ul class="list-unstyled">
                    <li class="mb-2">✅ Guided onboarding with API import</li>
                    <li class="mb-2">✅ Shared reporting dashboard</li>
                    <li class="mb-2">✅ Role-based access with audit trails</li>
                    <li class="mb-2">✅ Reliable data retention for 12 months</li>
                </ul>
            </div>
            <div class="col-md-6">
                <img class="img-fluid rounded-4" src="images/pattern-grid.svg" alt="" />
            </div>
        </div>
    </div>
</section>
