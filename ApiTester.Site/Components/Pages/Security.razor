@page "/security"

<section class="page-hero bg-light py-5">
    <div class="container">
        <h1 class="display-5 fw-bold">Security and compliance</h1>
        <p class="lead">ApiTester is designed to protect API data with layered controls, transparent audits, and enterprise-ready governance.</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-6">
                <h2 class="h4 fw-bold">Platform safeguards</h2>
                <p>We combine encryption, least-privilege access, and continuous monitoring to keep your environments secure.</p>
                <ul class="list-unstyled">
                    <li class="mb-2">✅ Encryption at rest and in transit with rotating keys</li>
                    <li class="mb-2">✅ Dedicated audit trails for test runs and configuration changes</li>
                    <li class="mb-2">✅ IP allowlists, SSO, and MFA for privileged users</li>
                </ul>
            </div>
            <div class="col-lg-6">
                <img class="img-fluid rounded-4 shadow-sm" src="images/hero-illustration.svg" alt="Illustration of the ApiTester security dashboard" />
            </div>
        </div>
        <div class="row g-4 mt-3">
            <div class="col-md-4">
                <div class="stat-card">
                    <h3 class="h6 text-uppercase">Compliance</h3>
                    <p>Aligned with SOC 2 Type II practices and privacy-first data handling.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <h3 class="h6 text-uppercase">Infrastructure</h3>
                    <p>Multi-region hosting with automated failover and daily backups.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <h3 class="h6 text-uppercase">Incident response</h3>
                    <p>24/7 response with runbooks, postmortems, and customer status updates.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="cta-section text-white py-5">
    <div class="container text-center">
        <h2 class="fw-bold">Need a security review?</h2>
        <p class="lead">Our team can share documentation, security posture summaries, and custom data residency details.</p>
        <a class="btn btn-light btn-lg" href="/contact">Contact security</a>
    </div>
</section>
