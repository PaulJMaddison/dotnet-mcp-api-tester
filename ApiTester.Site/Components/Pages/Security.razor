@page "/security"

@code {
    private SecurityComplianceContent Content { get; } = MarketingContent.Current.SecurityCompliance;
    private ApiTester.Site.Content.PageMetadata Metadata => Content.Metadata;
}

<PageTitle>@Metadata.Title</PageTitle>
<HeadContent>
    <meta name="description" content="@Metadata.Description" />
    <meta property="og:title" content="@Metadata.OgTitle" />
    <meta property="og:description" content="@Metadata.OgDescription" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@Metadata.CanonicalUrl" />
    <meta property="og:image" content="@Metadata.OgImage" />
    <meta property="og:image:alt" content="@Metadata.OgImageAlt" />
    <meta name="twitter:card" content="@MarketingContent.Current.Metadata.TwitterCard" />
    <meta name="twitter:title" content="@Metadata.OgTitle" />
    <meta name="twitter:description" content="@Metadata.OgDescription" />
    <meta name="twitter:image" content="@Metadata.OgImage" />
    <meta name="twitter:image:alt" content="@Metadata.OgImageAlt" />
    <link rel="canonical" href="@Metadata.CanonicalUrl" />
</HeadContent>

<section class="page-hero bg-light py-5">
    <div class="container">
        <h1 class="display-5 fw-bold">@Content.HeroTitle</h1>
        <p class="lead">@Content.HeroSubtitle</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-lg-6">
                <h2 class="h4 fw-bold">@Content.ControlsTitle</h2>
                <FeatureGrid Items="@Content.Controls"
                             TitleSelector="control => control.Title"
                             DescriptionSelector="control => control.Description"
                             ColumnClass="col-md-6"
                             TitleClass="h6 text-uppercase" />
            </div>
            <div class="col-lg-6">
                <div class="diagram-visual">
                    <img src="/images/docs/security-diagram.svg"
                         alt="Security controls pipeline showing spec intake, policy checks, runtime scans, and incident response"
                         class="img-fluid"
                         loading="lazy"
                         decoding="async" />
                </div>
            </div>
        </div>
        <div class="row g-4 mt-4">
            <div class="col-lg-4">
                <h3 class="h5 fw-bold">@Content.SsrfTitle</h3>
                <ul class="list-unstyled">
                    @foreach (var note in Content.SsrfNotes)
                    {
                        <li class="mb-2">@note</li>
                    }
                </ul>
            </div>
            <div class="col-lg-4">
                <h3 class="h5 fw-bold">@Content.DataHandlingTitle</h3>
                <ul class="list-unstyled">
                    @foreach (var note in Content.DataHandlingNotes)
                    {
                        <li class="mb-2">@note</li>
                    }
                </ul>
            </div>
            <div class="col-lg-4">
                <h3 class="h5 fw-bold">@Content.AuditTrailTitle</h3>
                <ul class="list-unstyled">
                    @foreach (var note in Content.AuditTrailNotes)
                    {
                        <li class="mb-2">@note</li>
                    }
                </ul>
            </div>
        </div>
        <div class="row g-4 mt-4">
            <div class="col-md-12">
                <h3 class="h5 fw-bold">@Content.RetentionTitle</h3>
                <ul class="list-unstyled">
                    @foreach (var note in Content.RetentionNotes)
                    {
                        <li class="mb-2">@note</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-6">
                <h2 class="h5 fw-bold">@Content.DisclosureTitle</h2>
                <p class="mb-3">@Content.DisclosureSubtitle</p>
                <a class="btn btn-outline-primary" href="@Content.DisclosureContactLink">@Content.DisclosureContactLabel</a>
            </div>
            <div class="col-lg-6">
                <h2 class="h5 fw-bold">@Content.StatusTitle</h2>
                <p class="mb-3">@Content.StatusSubtitle</p>
                <a class="btn btn-outline-primary" href="@Content.StatusLink">@Content.StatusLinkLabel</a>
            </div>
        </div>
    </div>
</section>

<section class="cta-section text-white py-5">
    <div class="container text-center">
        <h2 class="fw-bold">@Content.CtaTitle</h2>
        <p class="lead">@Content.CtaSubtitle</p>
        <a class="btn btn-light btn-lg" href="@Content.CtaLink">@Content.CtaLabel</a>
    </div>
</section>
