@page "/security"

@code {
    private SecurityComplianceContent Content { get; } = MarketingContent.Current.SecurityCompliance;
}

<section class="page-hero bg-light py-5">
    <div class="container">
        <h1 class="display-5 fw-bold">@Content.HeroTitle</h1>
        <p class="lead">@Content.HeroSubtitle</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-6">
                <h2 class="h4 fw-bold">@Content.ControlsTitle</h2>
                <ul class="list-unstyled">
                    @foreach (var control in Content.Controls)
                    {
                        <li class="mb-3">
                            <strong>@control.Title:</strong> @control.Description
                        </li>
                    }
                </ul>
            </div>
            <div class="col-lg-6">
                <figure class="diagram-visual">
                    <img class="img-fluid" src="/assets/marketing/security-compliance-shield.svg" alt="Security compliance shield illustrating governance controls." loading="lazy" />
                    <figcaption class="mt-3 text-muted small">
                        <span class="fw-semibold d-block">@Content.ControlsPlaceholder.Title</span>
                        @Content.ControlsPlaceholder.Description
                    </figcaption>
                </figure>
            </div>
        </div>
        <div class="row g-4 mt-3">
            <div class="col-md-12">
                <h3 class="h5 fw-bold">@Content.RetentionTitle</h3>
                <ul class="list-unstyled">
                    @foreach (var note in Content.RetentionNotes)
                    {
                        <li class="mb-2">@note</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</section>

<section class="cta-section text-white py-5">
    <div class="container text-center">
        <h2 class="fw-bold">@Content.CtaTitle</h2>
        <p class="lead">@Content.CtaSubtitle</p>
        <a class="btn btn-light btn-lg" href="@Content.CtaLink">@Content.CtaLabel</a>
    </div>
</section>
