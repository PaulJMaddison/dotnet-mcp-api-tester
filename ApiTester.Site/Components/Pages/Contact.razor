@page "/contact"
@using System.ComponentModel.DataAnnotations
@inject NavigationManager NavigationManager

<section class="page-hero bg-light py-5">
    <div class="container">
        <h1 class="display-5 fw-bold">Contact the ApiTester team</h1>
        <p class="lead">Tell us about your API program and we will help you find the right plan.</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-7">
                <EditForm class="contact-form" Model="LeadCapture" OnValidSubmit="HandleValidSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-danger" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" for="firstName">First name</label>
                            <InputText id="firstName" class="form-control" @bind-Value="LeadCapture.FirstName" placeholder="Avery" />
                            <ValidationMessage For="() => LeadCapture.FirstName" class="text-danger" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="lastName">Last name</label>
                            <InputText id="lastName" class="form-control" @bind-Value="LeadCapture.LastName" placeholder="Jordan" />
                            <ValidationMessage For="() => LeadCapture.LastName" class="text-danger" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="email">Work email</label>
                            <InputText id="email" type="email" class="form-control" @bind-Value="LeadCapture.Email" placeholder="avery@company.com" />
                            <ValidationMessage For="() => LeadCapture.Email" class="text-danger" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="company">Company</label>
                            <InputText id="company" class="form-control" @bind-Value="LeadCapture.Company" placeholder="Northwind" />
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="message">What would you like to achieve?</label>
                            <InputTextArea id="message" class="form-control" @bind-Value="LeadCapture.Message" rows="4" placeholder="We want to consolidate API testing across environments and improve release confidence." />
                            <ValidationMessage For="() => LeadCapture.Message" class="text-danger" />
                        </div>
                        <div class="visually-hidden">
                            <label class="form-label" for="website">Website</label>
                            <InputText id="website" class="form-control" @bind-Value="LeadCapture.Website" tabindex="-1" autocomplete="off" />
                        </div>
                        <div class="col-12">
                            <button class="btn btn-primary btn-lg" type="submit">Send request</button>
                        </div>
                    </div>
                </EditForm>
            </div>
            <div class="col-lg-5">
                <div class="contact-card">
                    <h2 class="h5 fw-bold">What happens next?</h2>
                    <p class="text-muted">Our team responds within one business day with a tailored walkthrough.</p>
                    <ul class="list-unstyled">
                        <li class="mb-2">✅ Review your current toolchain</li>
                        <li class="mb-2">✅ Map out environments and integrations</li>
                        <li class="mb-2">✅ Provide a custom rollout plan</li>
                    </ul>
                </div>
                <figure class="diagram-visual mt-4">
                    <img class="img-fluid rounded-4 visual-asset" src="images/conversion-flow.svg" alt="Workflow diagram showing lead intake, API audit, test plan, and launch steps." loading="lazy" decoding="async" />
                    <figcaption class="small text-muted mt-2">Conversion workflow that keeps onboarding momentum high.</figcaption>
                </figure>
            </div>
        </div>
    </div>
</section>

<section class="bg-white py-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <h2 class="fw-bold">How it works</h2>
                <p class="lead">Share your goals, connect your stack, and launch a pilot in weeks—not quarters.</p>
                <ol class="ps-3">
                    <li class="mb-2">Submit the form and we will map the right onboarding path.</li>
                    <li class="mb-2">We import your existing tests and align on success metrics.</li>
                    <li class="mb-2">Launch with shared dashboards, release gates, and executive reporting.</li>
                </ol>
                <div class="d-flex flex-wrap gap-3 mt-4">
                    <a class="btn btn-primary" href="/pricing">View pricing</a>
                    <a class="btn btn-outline-secondary" href="/features">See platform features</a>
                </div>
            </div>
            <div class="col-lg-6">
                <figure class="diagram-visual">
                    <img class="img-fluid rounded-4 visual-asset" src="images/conversion-integrations.svg" alt="Integration map showing spec sources flowing into the ApiTester hub and out to alerts and analytics." loading="lazy" decoding="async" />
                    <figcaption class="small text-muted mt-2">Integration map for connecting specs, pipelines, and alerts.</figcaption>
                </figure>
            </div>
        </div>
    </div>
</section>

<section class="cta-section text-white py-5">
    <div class="container text-center">
        <h2 class="fw-bold">Ready to turn API testing into a growth lever?</h2>
        <p class="lead">Book a demo or request a custom launch plan for your team.</p>
        <div class="d-flex flex-wrap justify-content-center gap-3">
            <a class="btn btn-light btn-lg" href="/contact">Get a demo</a>
            <a class="btn btn-outline-light btn-lg" href="/docs">Explore documentation</a>
        </div>
    </div>
</section>

@code {
    private LeadCaptureModel LeadCapture { get; } = new();

    private static readonly List<LeadCaptureSubmission> LeadSubmissions = new();

    private void HandleValidSubmit()
    {
        if (!string.IsNullOrWhiteSpace(LeadCapture.Website))
        {
            return;
        }

        LeadSubmissions.Add(new LeadCaptureSubmission(
            LeadCapture.FirstName,
            LeadCapture.LastName,
            LeadCapture.Email,
            LeadCapture.Company,
            LeadCapture.Message,
            DateTimeOffset.UtcNow));

        NavigationManager.NavigateTo("/contact/thanks");
    }

    private sealed class LeadCaptureModel
    {
        [Required(ErrorMessage = "First name is required.")]
        [StringLength(80)]
        public string? FirstName { get; set; }

        [Required(ErrorMessage = "Last name is required.")]
        [StringLength(80)]
        public string? LastName { get; set; }

        [Required(ErrorMessage = "Work email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid work email.")]
        public string? Email { get; set; }

        [StringLength(120)]
        public string? Company { get; set; }

        [Required(ErrorMessage = "Tell us what you want to achieve.")]
        [StringLength(500)]
        public string? Message { get; set; }

        public string? Website { get; set; }
    }

    private sealed record LeadCaptureSubmission(
        string? FirstName,
        string? LastName,
        string? Email,
        string? Company,
        string? Message,
        DateTimeOffset SubmittedAt);
}
