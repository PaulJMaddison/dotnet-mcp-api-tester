@page "/contact"

<section class="page-hero bg-light py-5">
    <div class="container">
        <h1 class="display-5 fw-bold">Contact the ApiTester team</h1>
        <p class="lead">Tell us about your API program and we will help you find the right plan.</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-7">
                <form class="contact-form" action="/contact/thanks" method="get">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" for="firstName">First name</label>
                            <input id="firstName" name="firstName" class="form-control" placeholder="Avery" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="lastName">Last name</label>
                            <input id="lastName" name="lastName" class="form-control" placeholder="Jordan" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="email">Work email</label>
                            <input id="email" name="email" type="email" class="form-control" placeholder="avery@company.com" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="company">Company</label>
                            <input id="company" name="company" class="form-control" placeholder="Northwind" />
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="message">What would you like to achieve?</label>
                            <textarea id="message" name="message" class="form-control" rows="4" placeholder="We want to consolidate API testing across environments and improve release confidence." required></textarea>
                        </div>
                        <div class="col-12">
                            <button class="btn btn-primary btn-lg" type="submit">Send request</button>
                        </div>
                    </div>
                </form>
            </div>
            <div class="col-lg-5">
                <div class="contact-card">
                    <h2 class="h5 fw-bold">What happens next?</h2>
                    <p class="text-muted">Our team responds within one business day with a tailored walkthrough.</p>
                    <ul class="list-unstyled">
                        <li class="mb-2">✅ Review your current toolchain</li>
                        <li class="mb-2">✅ Map out environments and integrations</li>
                        <li class="mb-2">✅ Provide a custom rollout plan</li>
                    </ul>
                </div>
                <img class="img-fluid rounded-4 mt-4" src="images/pattern-grid.svg" alt="" />
            </div>
        </div>
    </div>
</section>
