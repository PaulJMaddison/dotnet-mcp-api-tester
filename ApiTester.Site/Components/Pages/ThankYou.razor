@page "/thank-you"
@page "/contact/thanks"
@using ApiTester.Site.Content

@code {
    private const string Title = "Thanks for contacting ApiTester";
    private const string Description = "We received your ApiTester request and will follow up shortly with next steps.";
    private const string CanonicalUrl = "https://apitester.example.com/thank-you";
}

<PageTitle>@Title</PageTitle>
<HeadContent>
    <meta name="description" content="@Description" />
    <meta property="og:title" content="@Title" />
    <meta property="og:description" content="@Description" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@CanonicalUrl" />
    <meta property="og:image" content="https://apitester.example.com/assets/marketing/og-devqa-compliance.svg" />
    <meta property="og:image:alt" content="ApiTester marketing illustration" />
    <meta name="twitter:card" content="@MarketingContent.Current.Metadata.TwitterCard" />
    <meta name="twitter:title" content="@Title" />
    <meta name="twitter:description" content="@Description" />
    <meta name="twitter:image" content="https://apitester.example.com/assets/marketing/og-devqa-compliance.svg" />
    <meta name="twitter:image:alt" content="ApiTester marketing illustration" />
    <link rel="canonical" href="@CanonicalUrl" />
</HeadContent>

<section class="page-hero bg-light py-5">
    <div class="container">
        <h1 class="display-5 fw-bold">Thanks for reaching out</h1>
        <p class="lead">We received your request and will respond shortly with next steps.</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-7">
                <h2 class="h4 fw-bold">What to expect</h2>
                <p>One of our API specialists will follow up to understand your use case, review your current testing workflow, and outline a recommended rollout plan.</p>
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="stat-card">
                            <h3 class="h6 text-uppercase">Response time</h3>
                            <p class="mb-0">Within one business day.</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="stat-card">
                            <h3 class="h6 text-uppercase">Follow-up</h3>
                            <p class="mb-0">Customized walkthrough and pilot plan.</p>
                        </div>
                    </div>
                </div>
                <a class="btn btn-primary mt-4" href="/">Return to home</a>
            </div>
            <div class="col-lg-5">
                <img class="img-fluid rounded-4 visual-asset" src="images/pattern-grid.svg" alt="" loading="lazy" decoding="async" aria-hidden="true" />
            </div>
        </div>
    </div>
</section>
