@page "/"

@code {
    private HomePageContent Content { get; } = MarketingContent.Current.Home;
    private ApiTester.Site.Content.PageMetadata Metadata => Content.Metadata;

    private (string Src, string Alt) GetPersonaIcon(string title)
        => title switch
        {
            "Developer" => ("/assets/marketing/persona-dev-qa-engineer.svg", "Developer persona icon"),
            "QA" => ("/assets/marketing/persona-dev-qa-engineer.svg", "QA engineer persona icon"),
            "Compliance" => ("/assets/marketing/persona-security-compliance-lead.svg", "Compliance lead persona icon"),
            "Vibe coder" => ("/assets/marketing/ai-edgecases.svg", "Vibe coder persona icon"),
            _ => ("/images/personas-illustration.svg", "Persona illustration")
        };
}

<PageTitle>@Metadata.Title</PageTitle>
<HeadContent>
    <meta name="description" content="@Metadata.Description" />
    <meta property="og:title" content="@Metadata.OgTitle" />
    <meta property="og:description" content="@Metadata.OgDescription" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@Metadata.CanonicalUrl" />
    <meta property="og:image" content="@Metadata.OgImage" />
    <meta property="og:image:alt" content="@Metadata.OgImageAlt" />
    <meta name="twitter:card" content="@MarketingContent.Current.Metadata.TwitterCard" />
    <meta name="twitter:title" content="@Metadata.OgTitle" />
    <meta name="twitter:description" content="@Metadata.OgDescription" />
    <meta name="twitter:image" content="@Metadata.OgImage" />
    <meta name="twitter:image:alt" content="@Metadata.OgImageAlt" />
    <link rel="canonical" href="@Metadata.CanonicalUrl" />
</HeadContent>

<section class="hero-section bg-light py-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold">@Content.HeroTitle</h1>
                <p class="lead mt-3">@Content.HeroSubtitle</p>
                <div class="d-flex gap-3 mt-4">
                    <a class="btn btn-primary btn-lg" href="@Content.PrimaryCtaLink">@Content.PrimaryCtaLabel</a>
                    <a class="btn btn-outline-secondary btn-lg" href="@Content.SecondaryCtaLink">@Content.SecondaryCtaLabel</a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="diagram-visual">
                    <img src="/images/hero-illustration.svg"
                         alt="Illustration of deterministic API testing, AI edge case discovery, and evidence capture"
                         class="img-fluid" />
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 section-pattern-dots">
    <div class="container">
        <h2 class="fw-bold">@Content.PersonaTitle</h2>
        <div class="row g-4 mt-2">
            @foreach (var tile in Content.PersonaTiles)
            {
                var icon = GetPersonaIcon(tile.Title);
                <div class="col-md-6 col-lg-3">
                    <PersonaCard Title="@tile.Title"
                                 Outcome="@tile.Outcome"
                                 Proof="@tile.Proof"
                                 IconSrc="@icon.Src"
                                 IconAlt="@icon.Alt" />
                </div>
            }
        </div>
    </div>
</section>

<section class="bg-white py-5">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-lg-5">
                <h2 class="fw-bold">@Content.WorkflowTitle</h2>
                <p class="text-muted">@Content.WorkflowSubtitle</p>
                <ol class="ps-3">
                    @foreach (var step in Content.WorkflowSteps)
                    {
                        <li class="mb-2">
                            <strong>@step.Title:</strong> @step.Description
                        </li>
                    }
                </ol>
            </div>
            <div class="col-lg-7">
                <div class="diagram-placeholder">
                    <div class="placeholder-grid">@Content.WorkflowPlaceholder.Title</div>
                    <p class="mb-0">@Content.WorkflowPlaceholder.Description</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 section-pattern-grid">
    <div class="container">
        <h2 class="fw-bold">@Content.ProofTitle</h2>
        <FeatureGrid Items="@Content.ProofPoints"
                     TitleSelector="point => point.Title"
                     DescriptionSelector="point => point.Description"
                     ColumnClass="col-md-6 col-lg-3"
                     TitleClass="h6 text-uppercase" />
    </div>
</section>

<section class="py-5 bg-white">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-lg-6">
                <h2 class="fw-bold">Swagger documents the happy path, ApiTester probes what you missed.</h2>
                <p class="text-muted">
                    Import an OpenAPI spec, then let the platform generate and run coverage that looks like a senior engineer wrote it,
                    bounds checks, invalid enums, missing headers, auth mistakes, and other failure modes.
                    When you ask questions, answers are grounded in retrieved evidence, with citations.
                </p>

                <ul class="list-unstyled mt-3">
                    <li class="mb-2">✅ Generate a runnable test plan from the contract</li>
                    <li class="mb-2">✅ Expand edge cases safely, with deterministic guardrails</li>
                    <li class="mb-2">✅ Ask questions about endpoints, params, auth, and responses with citations</li>
                    <li class="mb-2">✅ Export evidence, run evals, track drift</li>
                </ul>

                <a class="btn btn-primary mt-3" href="/docs">Run the demo workflow</a>
            </div>

            <div class="col-lg-6">
                <div class="diagram-placeholder">
                    <div class="placeholder-grid">Evidence-first AI workflow</div>
                    <p class="mb-0">Planned visual highlighting MCP execution, AI analysis, and evidence exports.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="cta-section text-white py-5">
    <div class="container text-center">
        <h2 class="fw-bold">@Content.ClosingCtaTitle</h2>
        <p class="lead">@Content.ClosingCtaSubtitle</p>
        <a class="btn btn-light btn-lg" href="@Content.ClosingCtaLink">@Content.ClosingCtaLabel</a>
    </div>
</section>
