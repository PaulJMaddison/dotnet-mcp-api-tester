@page "/"

<section class="hero-section bg-light py-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <p class="text-uppercase text-primary fw-semibold mb-2">ApiTester Marketing Site</p>
                <h1 class="display-4 fw-bold">Ship reliable APIs with a testing workspace built for velocity.</h1>
                <p class="lead mt-3">ApiTester centralizes contract tests, monitors, and release gates so your team can move fast without breaking integrations.</p>
                <div class="d-flex gap-3 mt-4">
                    <a class="btn btn-primary btn-lg" href="/contact">Request a demo</a>
                    <a class="btn btn-outline-secondary btn-lg" href="/docs">Explore docs</a>
                </div>
                <div class="d-flex gap-4 mt-4 small text-muted">
                    <div>
                        <strong class="text-dark">500+</strong>
                        <span class="d-block">Teams onboarded</span>
                    </div>
                    <div>
                        <strong class="text-dark">99.9%</strong>
                        <span class="d-block">Test reliability score</span>
                    </div>
                    <div>
                        <strong class="text-dark">15 min</strong>
                        <span class="d-block">Average setup time</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <img class="img-fluid rounded-4 shadow-sm" src="images/hero-illustration.svg" alt="Illustration of the ApiTester workspace dashboard" />
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <h3 class="h5">Test orchestration</h3>
                        <p>Organize suites by environment, tag releases, and orchestrate runs across staging and production with confidence.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <h3 class="h5">Contract governance</h3>
                        <p>Keep schemas in sync with guided contract reviews, automated diffs, and alerts when changes break consumers.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <h3 class="h5">Release confidence</h3>
                        <p>Attach test results to every deployment so everyone knows what changed and how it was verified.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="bg-white py-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <img class="img-fluid rounded-4" src="images/pattern-grid.svg" alt="" />
            </div>
            <div class="col-lg-6">
                <h2 class="fw-bold">Designed for product, QA, and platform teams.</h2>
                <p class="lead">ApiTester brings roles together with shared visibility across specs, tests, and live metrics.</p>
                <ul class="list-unstyled">
                    <li class="mb-2">✅ Visual builders for non-developers, with YAML export for engineers.</li>
                    <li class="mb-2">✅ Live health indicators connected to uptime and latency monitors.</li>
                    <li class="mb-2">✅ Slack and email alerts tailored to release owners.</li>
                </ul>
                <a class="btn btn-outline-primary" href="/features">Explore feature details</a>
            </div>
        </div>
    </div>
</section>

<section class="cta-section text-white py-5">
    <div class="container text-center">
        <h2 class="fw-bold">Turn every API release into a predictable launch.</h2>
        <p class="lead">Start with guided onboarding, or connect your existing Postman, REST, or GraphQL suites today.</p>
        <a class="btn btn-light btn-lg" href="/contact">Talk to the team</a>
    </div>
</section>
