@page "/"

@code {
    private HomePageContent Content { get; } = MarketingContent.Current.Home;
    private IReadOnlyList<(string Src, string Alt)> PersonaVisuals { get; } = new List<(string, string)>
    {
        (
            "/assets/marketing/persona-dev-qa-engineer.svg",
            "Illustration of a developer coordinating with QA on release readiness."
        ),
        (
            "/assets/marketing/persona-dev-qa-engineer.svg",
            "Illustration of a QA engineer reviewing a test run summary."
        ),
        (
            "/assets/marketing/persona-security-compliance-lead.svg",
            "Illustration of a security and compliance lead with governance controls."
        )
    };
}

<section class="hero-section bg-light py-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold">@Content.HeroTitle</h1>
                <p class="lead mt-3">@Content.HeroSubtitle</p>
                <div class="d-flex gap-3 mt-4">
                    <a class="btn btn-primary btn-lg" href="@Content.PrimaryCtaLink">@Content.PrimaryCtaLabel</a>
                    <a class="btn btn-outline-secondary btn-lg" href="@Content.SecondaryCtaLink">@Content.SecondaryCtaLabel</a>
                </div>
            </div>
            <div class="col-lg-6">
                <figure class="diagram-visual h-100">
                    <img class="img-fluid" src="/assets/marketing/og-devqa-compliance.svg" alt="Illustration of developer, QA, and compliance teams sharing evidence." loading="lazy" />
                    <figcaption class="mt-3 text-muted small">
                        <span class="fw-semibold d-block">@Content.HeroPlaceholder.Title</span>
                        @Content.HeroPlaceholder.Description
                    </figcaption>
                </figure>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <h2 class="fw-bold">@Content.PersonaTitle</h2>
        <div class="row g-4 mt-2">
            @for (var index = 0; index < Content.PersonaTiles.Count; index++)
            {
                var tile = Content.PersonaTiles[index];
                var visual = PersonaVisuals[index % PersonaVisuals.Count];
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <img class="img-fluid persona-visual mb-3" src="@visual.Src" alt="@visual.Alt" loading="lazy" />
                            <h3 class="h5">@tile.Title</h3>
                            <p class="mb-2">@tile.Outcome</p>
                            <p class="text-muted mb-0">@tile.Proof</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section class="bg-white py-5">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-lg-5">
                <h2 class="fw-bold">@Content.WorkflowTitle</h2>
                <p class="text-muted">@Content.WorkflowSubtitle</p>
                <ol class="ps-3">
                    @foreach (var step in Content.WorkflowSteps)
                    {
                        <li class="mb-2">
                            <strong>@step.Title:</strong> @step.Description
                        </li>
                    }
                </ol>
            </div>
            <div class="col-lg-7">
                <figure class="diagram-visual">
                    <img class="img-fluid" src="/assets/marketing/workflow-dev-qa-validation.svg" alt="Workflow illustrating plan definition, controlled execution, and evidence sharing." loading="lazy" />
                    <figcaption class="mt-3 text-muted small">
                        <span class="fw-semibold d-block">@Content.WorkflowPlaceholder.Title</span>
                        @Content.WorkflowPlaceholder.Description
                    </figcaption>
                </figure>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <h2 class="fw-bold">@Content.ProofTitle</h2>
        <div class="row g-4 mt-2">
            @foreach (var proof in Content.ProofPoints)
            {
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <h3 class="h6 text-uppercase">@proof.Title</h3>
                            <p class="mb-0">@proof.Description</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section class="cta-section text-white py-5">
    <div class="container text-center">
        <h2 class="fw-bold">@Content.ClosingCtaTitle</h2>
        <p class="lead">@Content.ClosingCtaSubtitle</p>
        <a class="btn btn-light btn-lg" href="@Content.ClosingCtaLink">@Content.ClosingCtaLabel</a>
    </div>
</section>
