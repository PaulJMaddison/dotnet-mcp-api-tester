@using System.Reflection

<Router AppAssembly="@typeof(Program).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@SelectLayout(routeData)" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(Layout.MainLayout)">
            <section class="container py-5">
                <h1 class="display-6">Page not found</h1>
                <p class="lead">We couldn't find the page you requested. Try one of the main sections from the navigation.</p>
            </section>
        </LayoutView>
    </NotFound>
</Router>

@code {
    private static readonly Type MainLayout = typeof(Layout.MainLayout);
    private static readonly Type AppLayout = typeof(Layout.AppLayout);

    private static Type SelectLayout(RouteData routeData)
        => IsAppRoute(routeData) ? AppLayout : MainLayout;

    private static bool IsAppRoute(RouteData routeData)
    {
        var routes = routeData.PageType.GetCustomAttributes<RouteAttribute>();

        foreach (var route in routes)
        {
            var template = route.Template?.TrimStart('~').TrimStart('/');
            if (string.IsNullOrWhiteSpace(template))
            {
                continue;
            }

            if (template.StartsWith("app", StringComparison.OrdinalIgnoreCase)
                && !template.StartsWith("app/sign-in", StringComparison.OrdinalIgnoreCase)
                && !template.StartsWith("app/sign-out", StringComparison.OrdinalIgnoreCase))
            {
                return true;
            }
        }

        return false;
    }
}
