<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="@MarketingContent.Current.Metadata.Description" />
    <meta name="keywords" content="@MarketingContent.Current.Metadata.Keywords" />
    <meta name="author" content="@MarketingContent.Current.Metadata.Title" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="googlebot" content="index, follow, max-image-preview:large" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content="#1d4ed8" />
    <meta name="color-scheme" content="light" />
    <meta property="og:title" content="@MarketingContent.Current.Metadata.OgTitle" />
    <meta property="og:description" content="@MarketingContent.Current.Metadata.OgDescription" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@MarketingContent.Current.Metadata.CanonicalUrl" />
    <meta property="og:image" content="@MarketingContent.Current.Metadata.OgImage" />
    <meta property="og:image:alt" content="@MarketingContent.Current.Metadata.OgImageAlt" />
    <meta property="og:site_name" content="@MarketingContent.Current.Metadata.Title" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="@MarketingContent.Current.Metadata.TwitterCard" />
    <meta name="twitter:title" content="@MarketingContent.Current.Metadata.OgTitle" />
    <meta name="twitter:description" content="@MarketingContent.Current.Metadata.OgDescription" />
    <meta name="twitter:image" content="@MarketingContent.Current.Metadata.OgImage" />
    <meta name="twitter:image:alt" content="@MarketingContent.Current.Metadata.OgImageAlt" />
    <link rel="canonical" href="@MarketingContent.Current.Metadata.CanonicalUrl" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <link rel="preload" href="/images/hero-illustration.svg" as="image" fetchpriority="high" />
    <link rel="icon" type="image/svg+xml" href="images/logo-mark.svg" />
    <link rel="apple-touch-icon" href="images/logo-mark.svg" />
    <base href="/" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="css/site.css" />
    <title>@MarketingContent.Current.Metadata.Title</title>
</head>
<body>
    <Routes />
</body>
</html>
