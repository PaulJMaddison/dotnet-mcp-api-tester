@inherits LayoutComponentBase

@code {
    private LayoutContent Content { get; } = MarketingContent.Current.Layout;
}

<div class="site-shell">
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <header class="site-header border-bottom">
        <nav class="navbar navbar-expand-lg bg-white" aria-label="Primary">
            <div class="container">
                <NavLink class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/">
                    <img src="images/logo-mark.svg" alt="@Content.BrandName logo" width="32" height="32" decoding="async" />
                    <span>@Content.BrandName</span>
                </NavLink>
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 flex-row flex-wrap gap-3">
                    @foreach (var item in Content.Navigation)
                    {
                        <li class="nav-item">
                            <NavLink class="nav-link" href="@item.Url">@item.Label</NavLink>
                        </li>
                    }
                </ul>
            </div>
        </nav>
    </header>

    <main id="main-content" tabindex="-1">
        @Body
    </main>

    <footer class="site-footer bg-dark text-white mt-auto">
        <div class="container py-5">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5 class="fw-semibold">@Content.BrandName</h5>
                    <p class="text-white-50 mb-0">@Content.FooterSummary</p>
                </div>
                @foreach (var group in Content.FooterGroups)
                {
                    <div class="col-md-4">
                        <h6 class="text-uppercase text-white-50">@group.Title</h6>
                        <ul class="list-unstyled">
                            @foreach (var link in group.Links)
                            {
                                <li><NavLink class="footer-link" href="@link.Url">@link.Label</NavLink></li>
                            }
                        </ul>
                    </div>
                }
                <div class="col-md-4">
                    <h6 class="text-uppercase text-white-50">Contact</h6>
                    <p class="mb-1">@Content.ContactEmail</p>
                    <p class="mb-1">@Content.ContactPhone</p>
                    <p class="mb-0">@Content.ContactLocation</p>
                </div>
            </div>
            <div class="border-top border-secondary mt-4 pt-3 text-white-50 small">
                @Content.Copyright
            </div>
        </div>
    </footer>
</div>
