@inherits LayoutComponentBase

<div class="site-shell">
    <header class="site-header border-bottom">
        <nav class="navbar navbar-expand-lg bg-white">
            <div class="container">
                <NavLink class="navbar-brand fw-bold" href="/">ApiTester</NavLink>
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 flex-row flex-wrap gap-3">
                    <li class="nav-item"><NavLink class="nav-link" href="/features">Features</NavLink></li>
                    <li class="nav-item"><NavLink class="nav-link" href="/pricing">Pricing</NavLink></li>
                    <li class="nav-item"><NavLink class="nav-link" href="/security">Security</NavLink></li>
                    <li class="nav-item"><NavLink class="nav-link" href="/docs">Docs</NavLink></li>
                    <li class="nav-item"><NavLink class="nav-link" href="/contact">Contact</NavLink></li>
                </ul>
            </div>
        </nav>
    </header>

    <main>
        @Body
    </main>

    <footer class="site-footer bg-dark text-white mt-auto">
        <div class="container py-5">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5 class="fw-semibold">ApiTester</h5>
                    <p class="text-white-50 mb-0">A modern API testing hub that helps teams ship with confidence, share coverage, and keep releases stable.</p>
                </div>
                <div class="col-md-4">
                    <h6 class="text-uppercase text-white-50">Resources</h6>
                    <ul class="list-unstyled">
                        <li><NavLink class="footer-link" href="/docs">Documentation</NavLink></li>
                        <li><NavLink class="footer-link" href="/security">Security Center</NavLink></li>
                        <li><NavLink class="footer-link" href="/pricing">Pricing</NavLink></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="text-uppercase text-white-50">Contact</h6>
                    <p class="mb-1">Email: support@apitester.example.com</p>
                    <p class="mb-1">Phone: +1 (555) 014-2200</p>
                    <p class="mb-0">Location: 58 Harbor Lane, Seattle, WA</p>
                </div>
            </div>
            <div class="border-top border-secondary mt-4 pt-3 text-white-50 small">
                © 2024 ApiTester. All rights reserved.
            </div>
        </div>
    </footer>
</div>
