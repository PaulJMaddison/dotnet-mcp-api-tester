@page
@model ApiTester.Ui.Pages.Runs.IndexModel

@{
    ViewData["Title"] = "Runs";
}

@section Breadcrumb {
    <a href="/">Projects</a>
    <span>/</span>
    <a href="/Runs">Runs</a>
}

<h1>Runs</h1>

<p class="page-intro">Review test runs filtered by project and operation.</p>

<section class="filter-summary">
    <h2>Filters</h2>
    <div class="summary-grid">
        <div class="summary-card">
            <span>Project Key</span>
            <strong>@(string.IsNullOrWhiteSpace(Model.ProjectKey) ? "None selected" : Model.ProjectKey)</strong>
        </div>
        <div class="summary-card">
            <span>Operation ID</span>
            <strong>@(string.IsNullOrWhiteSpace(Model.OperationId) ? "Any operation" : Model.OperationId)</strong>
        </div>
        <div class="summary-card">
            <span>Take</span>
            <strong>@Model.Take</strong>
        </div>
    </div>
    <p class="filter-hint">Provide <strong>projectKey</strong> and optional <strong>operationId</strong> query parameters to refine the list.</p>
</section>

@if (Model.HasError)
{
    <partial name="Shared/_ErrorPanel" model="new ErrorPanelModel(Model.ErrorMessage!, Model.ErrorDetails)" />
}
else if (Model.IsLoading)
{
    <div class="loading-state" role="status">Loading runs…</div>
}
else if (string.IsNullOrWhiteSpace(Model.ProjectKey))
{
    <partial name="Shared/_EmptyState" model='new EmptyStateModel("Select a project to view runs. Example: /Runs?projectKey=your-project")' />
}
else if (Model.Runs.Count == 0)
{
    <partial name="Shared/_EmptyState" model='new EmptyStateModel("No runs match the current filters.")' />
}
else
{
    <table>
        <thead>
            <tr>
                <th>Run ID</th>
                <th>Operation ID</th>
                <th>Started UTC</th>
                <th>Completed UTC</th>
                <th>Passed</th>
                <th>Failed</th>
                <th>Blocked</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var run in Model.Runs)
            {
                <tr>
                    <td><a href="/Runs/@run.RunId">@run.RunId</a></td>
                    <td>@run.OperationId</td>
                    <td>@DisplayFormatters.FormatUtc(run.StartedUtc)</td>
                    <td>@DisplayFormatters.FormatUtc(run.CompletedUtc)</td>
                    <td>@run.Snapshot.Passed</td>
                    <td>@run.Snapshot.Failed</td>
                    <td>@run.Snapshot.Blocked</td>
                </tr>
            }
        </tbody>
    </table>
}
