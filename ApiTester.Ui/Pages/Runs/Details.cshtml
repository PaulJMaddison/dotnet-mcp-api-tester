@page "/Runs/{runId:guid}"
@model ApiTester.Ui.Pages.Runs.DetailsModel

@{
    ViewData["Title"] = "Run Details";

    var header = new PageHeaderModel(
        "Run Details",
        "Review the results and diagnostics captured for this run.",
        new[]
        {
            new BreadcrumbItem("Projects", "/"),
            new BreadcrumbItem("Runs", "/Runs"),
            new BreadcrumbItem("Run Details")
        }
    );
}

<partial name="Shared/_PageHeader" model="header" />

@if (Model.HasError)
{
    <partial name="Shared/_ErrorPanel" model="new ErrorPanelModel(Model.ErrorMessage!, Model.ErrorDetails)" />
}
else if (Model.IsLoading)
{
    <div class="loading-state" role="status">Loading run details…</div>
}
else if (Model.NotFound)
{
    <partial name="Shared/_EmptyState" model='new EmptyStateModel("Run not found.")' />
}
else if (Model.Run is not null)
{
    var classification = Model.Run.Result.ClassificationSummary;
    var realFail = classification.Fail + classification.BlockedUnexpected;

    <h2>Run Summary</h2>
    <div class="summary-grid">
        <div class="summary-card">
            <span>Total Cases</span>
            <strong>@Model.Run.Result.TotalCases</strong>
        </div>
        <div class="summary-card">
            <span>Passed</span>
            <strong>@classification.Pass</strong>
        </div>
        <div class="summary-card">
            <span>Expected Blocked</span>
            <strong>@classification.BlockedExpected</strong>
        </div>
        <div class="summary-card">
            <span>Flaky</span>
            <strong>@classification.FlakyExternal</strong>
        </div>
        <div class="summary-card">
            <span>Real Fail</span>
            <strong>@realFail</strong>
        </div>
        <div class="summary-card">
            <span>Total Duration (ms)</span>
            <strong>@DisplayFormatters.FormatDurationMs(Model.Run.Result.TotalDurationMs)</strong>
        </div>
        <div class="summary-card">
            <span>Project Key</span>
            <strong>@Model.Run.ProjectKey</strong>
        </div>
        <div class="summary-card">
            <span>Operation ID</span>
            <strong>@Model.Run.OperationId</strong>
        </div>
        <div class="summary-card">
            <span>Started UTC</span>
            <strong>@DisplayFormatters.FormatUtc(Model.Run.StartedUtc)</strong>
        </div>
        <div class="summary-card">
            <span>Completed UTC</span>
            <strong>@DisplayFormatters.FormatUtc(Model.Run.CompletedUtc)</strong>
        </div>
    </div>

    <h2>Case Results</h2>
    @if (Model.Run.Result.Results.Count == 0)
    {
        <partial name="Shared/_EmptyState" model='new EmptyStateModel("No case results recorded.")' />
    }
    else
    {
        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Status</th>
                        <th>Status Code</th>
                        <th>Duration (ms)</th>
                        <th>Method</th>
                        <th>URL</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var result in Model.Run.Result.Results)
                    {
                        <tr>
                            <td>@result.Name</td>
                            <td>
                                @(result.Blocked
                                    ? "Blocked"
                                    : result.IsFlaky
                                        ? "Flaky"
                                        : result.Pass
                                            ? "Passed"
                                            : "Failed")
                            </td>
                            <td>@(result.StatusCode?.ToString() ?? "—")</td>
                            <td class="table-number">@DisplayFormatters.FormatDurationMs(result.DurationMs)</td>
                            <td>@(string.IsNullOrWhiteSpace(result.Method) ? "—" : result.Method)</td>
                            <td>@(string.IsNullOrWhiteSpace(result.Url) ? "—" : result.Url)</td>
                        </tr>
                        <tr class="details-row">
                            <td colspan="6">
                                <div class="details-stack">
                                    <details>
                                        <summary>Failure Reason</summary>
                                        <p>@(string.IsNullOrWhiteSpace(result.FailureReason) ? "None" : result.FailureReason)</p>
                                    </details>
                                    <details>
                                        <summary>Block Reason</summary>
                                        <p>@(string.IsNullOrWhiteSpace(result.BlockReason) ? "None" : result.BlockReason)</p>
                                    </details>
                                    <details>
                                        <summary>Response Snippet</summary>
                                        <pre class="code-block">@(string.IsNullOrWhiteSpace(result.ResponseSnippet) ? "None" : result.ResponseSnippet)</pre>
                                    </details>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}
