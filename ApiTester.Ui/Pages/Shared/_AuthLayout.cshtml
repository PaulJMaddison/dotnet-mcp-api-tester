@{
    var pageTitle = ViewData["Title"] as string ?? "Api Tester";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@pageTitle</title>
    <link rel="stylesheet" href="~/styles/site.css" />
</head>
<body>
    <div class="auth-shell">
        <div class="auth-panel">
            <main class="auth-card">
                @RenderBody()
            </main>
            <aside class="auth-visual" aria-hidden="true">
                <img src="~/images/auth-illustration.svg" alt="" />
                <div class="auth-visual-copy">
                    <span class="eyebrow">Secure access</span>
                    <p>Connect your workspace key once to unlock projects, runs, and onboarding guidance.</p>
                </div>
            </aside>
        </div>
    </div>
</body>
</html>
