@{
    var pageTitle = ViewData["Title"] as string ?? "Api Tester";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@pageTitle</title>
    <link rel="stylesheet" href="~/styles/site.css" />
</head>
<body>
    <div class="app-shell">
        <aside class="app-sidebar">
            <div class="sidebar-header">
                <a class="sidebar-brand" href="/Projects">
                    <img src="~/images/app-logo.svg" alt="API Tester" width="156" height="32" />
                </a>
            </div>
            <nav class="sidebar-nav" aria-label="Primary">
                <a href="/Projects">Projects</a>
                <a href="/Runs">Runs</a>
            </nav>
            <div class="sidebar-footer">
                <p>Sidebar placeholder</p>
            </div>
        </aside>

        <div class="app-main">
            <header class="app-topbar">
                <div class="topbar-left">
                    <div class="topbar-brand">
                        <img src="~/images/app-mark.svg" alt="" width="28" height="28" aria-hidden="true" />
                        <strong>API Tester</strong>
                    </div>
                    <span>Logged in: Demo User</span>
                </div>
                <div class="topbar-right">
                    <span>Workspace: Local</span>
                </div>
            </header>

            <div class="app-content">
                @if (IsSectionDefined("Breadcrumb"))
                {
                    <nav class="breadcrumbs" aria-label="Breadcrumb">
                        <img class="breadcrumb-icon" src="~/images/app-icon.svg" alt="" width="18" height="18" aria-hidden="true" />
                        @RenderSection("Breadcrumb")
                    </nav>
                }
                <main class="page">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>
</body>
</html>
