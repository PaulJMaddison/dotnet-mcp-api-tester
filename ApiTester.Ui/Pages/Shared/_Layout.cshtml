@using ApiTester.Ui.Auth
@using ApiTester.Ui.Onboarding
@inject ApiKeySessionStore ApiKeySessionStore
@inject OnboardingSessionStore OnboardingSessionStore

@{
    var pageTitle = ViewData["Title"] as string ?? "Api Tester";
    var isSignedIn = ApiKeySessionStore.TryGetApiKey(out var apiKey);
    var maskedKey = ApiKeyDisplay.Mask(apiKey);
    var onboardingComplete = isSignedIn && OnboardingSessionStore.IsComplete();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@pageTitle</title>
    <link rel="stylesheet" href="~/styles/site.css" />
</head>
<body>
    <div class="app-shell">
        <header class="app-header">
            <div class="app-header-inner page-container">
                <div class="nav-left">
                    <a class="nav-brand" href="/">API Tester</a>
                    <nav class="nav-links" aria-label="Primary">
                        <a class="nav-link" href="/">Projects</a>
                        <a class="nav-link" href="/Runs">Runs</a>
                        <a class="nav-link" href="/Onboarding">Onboarding</a>
                    </nav>
                </div>
                <div class="nav-meta">
                    <span>Workspace: <strong>Local</strong></span>
                    <span>API key: <strong>@maskedKey</strong></span>
                    @if (isSignedIn)
                    {
                        <form class="inline-form" method="post" asp-page="/Auth/SignOut">
                            @Html.AntiForgeryToken()
                            <button class="button button-ghost" type="submit" data-testid="sign-out-button">Sign out</button>
                        </form>
                    }
                </div>
            </div>
        </header>

        <div class="app-content">
            <main class="page page-container">
                @RenderBody()
            </main>
        </div>

        <footer class="app-footer">
            <div class="page-container">
                <span>@(onboardingComplete ? "Onboarding complete" : "Onboarding in progress")</span>
            </div>
        </footer>
    </div>
</body>
</html>
