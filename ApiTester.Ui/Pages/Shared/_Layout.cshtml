@using ApiTester.Ui.Auth
@using ApiTester.Ui.Onboarding
@inject ApiKeySessionStore ApiKeySessionStore
@inject OnboardingSessionStore OnboardingSessionStore

@{
    var pageTitle = ViewData["Title"] as string ?? "Api Tester";
    var isSignedIn = ApiKeySessionStore.TryGetApiKey(out var apiKey);
    var maskedKey = ApiKeyDisplay.Mask(apiKey);
    var onboardingComplete = isSignedIn && OnboardingSessionStore.IsComplete();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@pageTitle</title>
    <link rel="icon" type="image/svg+xml" href="~/images/app-icon.svg" />
    <link rel="stylesheet" href="~/styles/site.css" />
</head>
<body>
    <div class="app-shell">
        <aside class="app-sidebar">
            <div class="sidebar-header">
                <a class="sidebar-brand" href="/Projects">
                    <img class="brand-mark" src="~/images/app-mark.svg" alt="API Tester" width="36" height="36" />
                    <span>API Tester</span>
                </a>
            </div>
            <nav class="sidebar-nav" aria-label="Primary">
                <a href="/Projects">Projects</a>
                <a href="/Runs">Runs</a>
                <a href="/Onboarding">Onboarding</a>
            </nav>
            <div class="sidebar-footer">
                <p>@(onboardingComplete ? "Onboarding complete" : "Onboarding in progress")</p>
            </div>
        </aside>

        <div class="app-main">
            <header class="app-topbar">
                <div class="topbar-left">
                    <div class="topbar-brand">
                        <img class="brand-icon" src="~/images/app-icon.svg" alt="" width="24" height="24" />
                        <strong>API Tester</strong>
                    </div>
                    <span>API key: @maskedKey</span>
                </div>
                <div class="topbar-right">
                    <span>Workspace: Local</span>
                    @if (isSignedIn)
                    {
                        <form class="inline-form" method="post" asp-page="/Auth/SignOut">
                            @Html.AntiForgeryToken()
                            <button class="button button-ghost" type="submit">Sign out</button>
                        </form>
                    }
                </div>
            </header>

            <div class="app-content">
                @if (IsSectionDefined("Breadcrumb"))
                {
                    <nav class="breadcrumbs" aria-label="Breadcrumb">
                        @RenderSection("Breadcrumb")
                    </nav>
                }
                <main class="page">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>
</body>
</html>
