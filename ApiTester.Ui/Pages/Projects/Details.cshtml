@page "/projects/{projectId:guid}"
@model ApiTester.Ui.Pages.Projects.DetailsModel

@{
    ViewData["Title"] = "Runs";

    var projectName = Model.Project is null
        ? "Project"
        : string.IsNullOrWhiteSpace(Model.Project.Name)
            ? Model.Project.ProjectKey
            : Model.Project.Name;
    var header = new PageHeaderModel(
        "Project Runs",
        "Track runs recorded for this project.",
        new[]
        {
            new BreadcrumbItem("Projects", "/"),
            new BreadcrumbItem(projectName),
            new BreadcrumbItem("Runs")
        }
    );
}

<partial name="Shared/_PageHeader" model="header" />

@if (Model.HasError)
{
    <partial name="Shared/_ErrorPanel" model="new ErrorPanelModel(Model.ErrorMessage!, Model.ErrorDetails)" />
}
else if (Model.IsLoading)
{
    <div class="loading-state" role="status">Loading runs…</div>
}
else if (Model.NotFound)
{
    <partial name="Shared/_EmptyState" model='new EmptyStateModel("Project not found.")' />
}
else if (Model.Project is not null)
{
    <section class="toolbar" aria-label="Run filters">
        <div class="toolbar-grid">
            <div class="toolbar-item">
                <span>Project</span>
                <strong>@(string.IsNullOrWhiteSpace(Model.Project.Name) ? Model.Project.ProjectKey : Model.Project.Name)</strong>
            </div>
            <div class="toolbar-item">
                <span>Project Key</span>
                <strong>@Model.Project.ProjectKey</strong>
            </div>
            <div class="toolbar-item">
                <span>Operation ID</span>
                <strong>@(string.IsNullOrWhiteSpace(Model.OperationId) ? "Any operation" : Model.OperationId)</strong>
            </div>
            <div class="toolbar-item">
                <span>Take</span>
                <strong>@Model.Take</strong>
            </div>
        </div>
    </section>

    if (Model.Runs.Count == 0)
    {
        <partial name="Shared/_EmptyState" model='new EmptyStateModel("No runs have been recorded for this project yet.")' />
    }
    else
    {
        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th scope="col">Run ID</th>
                        <th scope="col">Operation ID</th>
                        <th scope="col">Started UTC</th>
                        <th scope="col">Completed UTC</th>
                        <th scope="col" class="table-number">Passed</th>
                        <th scope="col" class="table-number">Expected Blocked</th>
                        <th scope="col" class="table-number">Flaky</th>
                        <th scope="col" class="table-number">Real Fail</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var run in Model.Runs)
                    {
                        <tr>
                            <td><a href="/Runs/@run.RunId">@run.RunId</a></td>
                            <td>@run.OperationId</td>
                            <td>@DisplayFormatters.FormatUtc(run.StartedUtc)</td>
                            <td>@DisplayFormatters.FormatUtc(run.CompletedUtc)</td>
                            <td class="table-number">@run.Snapshot.Passed</td>
                            <td class="table-number">@run.Snapshot.ExpectedBlocked</td>
                            <td class="table-number">@run.Snapshot.Flaky</td>
                            <td class="table-number">@run.Snapshot.RealFail</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}
