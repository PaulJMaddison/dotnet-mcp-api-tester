@page "{projectId:guid}"
@model ApiTester.Ui.Pages.Projects.IndexModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Project Runs</title>
    <style>
        body {
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            margin: 2rem;
            color: #1f2933;
        }

        .top-nav {
            margin-bottom: 0.75rem;
            font-size: 0.95rem;
        }

        .top-nav a {
            font-weight: 600;
            color: #111827;
            text-decoration: none;
        }

        .top-nav a:hover {
            text-decoration: underline;
        }

        .breadcrumbs {
            display: flex;
            gap: 0.5rem;
            align-items: center;
            font-size: 0.9rem;
            color: #52606d;
            margin-bottom: 1.5rem;
        }

        .breadcrumbs a {
            color: #2563eb;
            text-decoration: none;
        }

        .breadcrumbs a:hover {
            text-decoration: underline;
        }

        h1 {
            margin-bottom: 0.25rem;
        }

        .project-meta {
            margin-top: 0;
            color: #52606d;
        }

        .filter-form {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            align-items: end;
            margin: 1.5rem 0 1rem;
        }

        .filter-form label {
            display: block;
            font-weight: 600;
            margin-bottom: 0.25rem;
        }

        .filter-form input,
        .filter-form select {
            padding: 0.5rem;
            border: 1px solid #cbd2d9;
            border-radius: 6px;
            min-width: 200px;
        }

        .filter-form button {
            padding: 0.6rem 1.2rem;
            border-radius: 6px;
            border: none;
            background: #2563eb;
            color: #fff;
            font-weight: 600;
            cursor: pointer;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1rem;
        }

        th, td {
            text-align: left;
            padding: 0.75rem 0.5rem;
            border-bottom: 1px solid #e5e7eb;
        }

        th {
            font-weight: 600;
            color: #374151;
        }

        .empty-state,
        .error-state {
            margin-top: 1rem;
            padding: 1rem;
            background: #f9fafb;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
        }

        details {
            margin-top: 0.5rem;
        }

        pre {
            margin: 0.5rem 0 0;
            white-space: pre-wrap;
            word-break: break-word;
            font-family: ui-monospace, "SFMono-Regular", Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
            font-size: 0.9rem;
        }

        a {
            color: #2563eb;
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <nav class="top-nav">
        <a href="/">Projects</a>
    </nav>
    <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Projects</a>
        <span>/</span>
        <span>Runs</span>
    </nav>

    <h1>Runs</h1>
    <p class="project-meta">
        Project:
        <strong>@(Model.ProjectName ?? Model.ProjectId.ToString())</strong>
        @if (!string.IsNullOrWhiteSpace(Model.ProjectName))
        {
            <span>(@Model.ProjectId)</span>
        }
    </p>

    <form method="get" class="filter-form">
        <div>
            <label for="operationId">OperationId</label>
            <input id="operationId" name="operationId" type="text" value="@(Model.OperationId ?? string.Empty)" />
        </div>
        <div>
            <label for="take">Take</label>
            <select id="take" name="take">
                <option value="10" selected="@(Model.Take == 10 ? "selected" : null)">10</option>
                <option value="20" selected="@(Model.Take == 20 ? "selected" : null)">20</option>
                <option value="50" selected="@(Model.Take == 50 ? "selected" : null)">50</option>
            </select>
        </div>
        <button type="submit">Filter</button>
    </form>

    @if (Model.HasError)
    {
        <partial name="Shared/_ErrorPanel" model="new ErrorPanelModel(Model.ErrorMessage!, Model.ErrorDetails)" />
    }
    else if (Model.Runs.Count == 0)
    {
        <partial name="Shared/_EmptyState" model="new EmptyStateModel(\"No runs for this project yet.\")" />
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>StartedUtc</th>
                    <th>OperationId</th>
                    <th>TotalCases</th>
                    <th>Passed</th>
                    <th>Failed</th>
                    <th>Blocked</th>
                    <th>TotalDurationMs</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var run in Model.Runs)
                {
                    <tr>
                        <td>
                            <a href="/runs/@run.RunId">@DisplayFormatters.FormatUtc(run.StartedUtc)</a>
                        </td>
                        <td>@run.OperationId</td>
                        <td>@run.Snapshot.TotalCases</td>
                        <td>@run.Snapshot.Passed</td>
                        <td>@run.Snapshot.Failed</td>
                        <td>@run.Snapshot.Blocked</td>
                        <td>@DisplayFormatters.FormatDurationMs(run.Snapshot.TotalDurationMs)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</body>
</html>
