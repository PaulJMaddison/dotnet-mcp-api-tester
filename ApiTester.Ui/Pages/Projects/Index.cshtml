@page "{projectId:guid}"
@model ApiTester.Ui.Pages.Projects.IndexModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Project Runs</title>
    <link rel="stylesheet" href="~/styles/site.css" />
</head>
<body>
    <main class="page">
        <nav class="top-nav">
            <a href="/">Projects</a>
        </nav>
        <nav class="breadcrumbs" aria-label="Breadcrumb">
            <a href="/">Projects</a>
            <span>/</span>
            <span>Runs</span>
        </nav>

        <h1>Runs</h1>
        <p class="project-meta">
            Project:
            <strong>@(Model.ProjectName ?? Model.ProjectId.ToString())</strong>
            @if (!string.IsNullOrWhiteSpace(Model.ProjectName))
            {
                <span>(@Model.ProjectId)</span>
            }
        </p>

        <section class="import-panel" aria-label="OpenAPI Import">
            <h2>Import OpenAPI</h2>
            <p>Upload an OpenAPI JSON file or provide a local server path to import into this project.</p>

            <form method="post" enctype="multipart/form-data" asp-page-handler="Import">
                <div>
                    <label for="openapi-file">OpenAPI JSON file</label>
                    <input id="openapi-file" type="file" name="OpenApiFile" accept=".json,application/json" />
                </div>
                <div>
                    <label for="openapi-path">Server file path (optional)</label>
                    <input id="openapi-path" type="text" name="OpenApiPath" value="@(Model.OpenApiPath ?? string.Empty)" placeholder="/path/to/openapi.json" />
                </div>
                <button type="submit">Import spec</button>
            </form>

            @if (Model.OpenApiSpec is not null)
            {
                <p>
                    Current spec:
                    <strong>@Model.OpenApiSpec.Title</strong>
                    <span>(@Model.OpenApiSpec.Version)</span>
                    <span>imported @DisplayFormatters.FormatUtc(Model.OpenApiSpec.CreatedUtc)</span>
                </p>
            }
            else
            {
                <p>No OpenAPI spec imported yet.</p>
            }

            @if (!string.IsNullOrWhiteSpace(Model.ImportMessage))
            {
                <div class="import-message @Model.ImportMessageKind">
                    @Model.ImportMessage
                </div>
            }
        </section>

        <section class="plan-panel" aria-label="Test Plan">
            <h2>Test Plan</h2>
            <p>Generate and store a deterministic test plan per operation.</p>

            <form method="post" asp-page-handler="GeneratePlan">
                <div>
                    <label for="testplan-operation">Operation ID</label>
                    <input id="testplan-operation" type="text" name="TestPlanOperationId" value="@(Model.OperationId ?? string.Empty)" />
                </div>
                <button type="submit">Generate plan</button>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.TestPlanMessage))
            {
                <div class="plan-message @Model.TestPlanMessageKind">
                    @Model.TestPlanMessage
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.RunMessage))
            {
                <div class="plan-message @Model.RunMessageKind">
                    @Model.RunMessage
                </div>
            }

            @if (Model.TestPlan is not null)
            {
                <p>
                    Stored plan for <strong>@Model.TestPlan.OperationId</strong>
                    generated @DisplayFormatters.FormatUtc(Model.TestPlan.CreatedUtc).
                </p>
                <form method="post" asp-page-handler="RunPlan">
                    <input type="hidden" name="RunOperationId" value="@Model.TestPlan.OperationId" />
                    <button type="submit">Run now</button>
                </form>
                <pre>@Model.TestPlan.PlanJson</pre>
            }
            else if (!string.IsNullOrWhiteSpace(Model.OperationId))
            {
                <p>No stored test plan for this operation yet.</p>
            }
        </section>

        <form method="get" class="filter-form">
            <div>
                <label for="operationId">Operation ID</label>
                <input id="operationId" name="operationId" type="text" value="@(Model.OperationId ?? string.Empty)" />
            </div>
            <div>
                <label for="take">Take</label>
                <select id="take" name="take">
                    <option value="10" selected="@(Model.Take == 10 ? "selected" : null)">10</option>
                    <option value="20" selected="@(Model.Take == 20 ? "selected" : null)">20</option>
                    <option value="50" selected="@(Model.Take == 50 ? "selected" : null)">50</option>
                </select>
            </div>
            <button type="submit">Filter</button>
        </form>

        @if (Model.HasError)
        {
            <partial name="Shared/_ErrorPanel" model="new ErrorPanelModel(Model.ErrorMessage!, Model.ErrorDetails)" />
        }
        else if (Model.Runs.Count == 0)
        {
            <partial name="Shared/_EmptyState" model='new EmptyStateModel("No runs for this project yet.")' />
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>Started UTC</th>
                        <th>Operation ID</th>
                        <th>Total Cases</th>
                        <th>Passed</th>
                        <th>Failed</th>
                        <th>Blocked</th>
                        <th>Total Duration (ms)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var run in Model.Runs)
                    {
                        <tr>
                            <td>
                                <a href="/runs/@run.RunId">@DisplayFormatters.FormatUtc(run.StartedUtc)</a>
                            </td>
                            <td>@run.OperationId</td>
                            <td>@run.Snapshot.TotalCases</td>
                            <td>@run.Snapshot.Passed</td>
                            <td>@run.Snapshot.Failed</td>
                            <td>@run.Snapshot.Blocked</td>
                            <td>@DisplayFormatters.FormatDurationMs(run.Snapshot.TotalDurationMs)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </main>
</body>
</html>
