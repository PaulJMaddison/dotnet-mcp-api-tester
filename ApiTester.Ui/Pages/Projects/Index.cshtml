@page
@model ApiTester.Ui.Pages.Projects.IndexModel

@{
    ViewData["Title"] = "Projects";

    var header = new PageHeaderModel(
        "Projects",
        "Browse all projects connected to the API tester service.",
        new[] { new BreadcrumbItem("Projects", "/") }
    );
}

<partial name="Shared/_PageHeader" model="header" />
<p class="page-hint">Create a project by running the client or API against your workspace key.</p>

@if (Model.HasError)
{
    <partial name="Shared/_ErrorPanel" model="new ErrorPanelModel(Model.ErrorMessage!, Model.ErrorDetails)" />
}
else if (Model.IsLoading)
{
    <div class="loading-state" role="status">Loading projects…</div>
}
else if (Model.Projects.Count == 0)
{
    <partial name="Shared/_EmptyState" model='new EmptyStateModel("No projects yet, create one by running the client or API.")' />
}
else
{
    <div class="table-card">
        <table data-testid="projects-table">
            <thead>
                <tr>
                    <th scope="col">Name</th>
                    <th scope="col">Project Key</th>
                    <th scope="col">Created UTC</th>
                    <th scope="col">Project ID</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var project in Model.Projects)
                {
                    <tr data-testid="project-row">
                        <td>@(string.IsNullOrWhiteSpace(project.Name) ? "Untitled Project" : project.Name)</td>
                        <td>
                            <a href="/projects/@project.ProjectId" data-testid="project-link">@project.ProjectKey</a>
                        </td>
                        <td>@DisplayFormatters.FormatUtc(project.CreatedUtc)</td>
                        <td>@project.ProjectId</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
