@page "/app/operations/{operationId}"
@model ApiTester.Ui.Pages.Operations.DetailsModel

@{
    ViewData["Title"] = "Operation Describe";

    var opId = Model.Operation?.OperationId ?? "Operation";
    var header = new PageHeaderModel(
        "Operation Describe",
        "Review parameters and responses for a selected API operation.",
        new[]
        {
            new BreadcrumbItem("Projects", "/"),
            new BreadcrumbItem("Specs", "/app/specs"),
            new BreadcrumbItem(opId)
        }
    );
}

<partial name="Shared/_PageHeader" model="header" />

@if (Model.HasError)
{
    <partial name="Shared/_ErrorPanel" model="new ErrorPanelModel(Model.ErrorMessage!, Model.ErrorDetails)" />
}
else if (Model.NotFound)
{
    <partial name="Shared/_EmptyState" model='new EmptyStateModel("Operation not found.")' />
}
else if (Model.Operation is not null)
{
    <section class="toolbar" aria-label="Operation metadata">
        <div class="toolbar-grid">
            <div class="toolbar-item"><span>Operation ID</span><strong>@Model.Operation.OperationId</strong></div>
            <div class="toolbar-item"><span>Method</span><strong>@Model.Operation.Method</strong></div>
            <div class="toolbar-item"><span>Path</span><strong>@Model.Operation.Path</strong></div>
            <div class="toolbar-item"><span>Auth</span><strong>@(Model.Operation.RequiresAuth ? "Required" : "None")</strong></div>
        </div>
    </section>

    <section class="ai-toolbar" aria-label="AI actions">
        <form method="post" asp-page-handler="Explain">
            <input type="hidden" asp-for="ProjectId" />
            <button class="button" type="submit">AI: Explain operation</button>
        </form>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.AiBlockedAction))
    {
        <section class="ai-gate-panel" role="status" aria-live="polite">
            <h3>Upgrade required</h3>
            <ul>
                <li><strong>Blocked action:</strong> @Model.AiBlockedAction</li>
                <li><strong>Why blocked:</strong> @Model.AiBlockedReason</li>
                <li><strong>Required plan:</strong> @Model.AiRequiredPlan</li>
                <li><strong>Remaining quota:</strong> @Model.AiRemainingQuota</li>
            </ul>
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(Model.AiOutput))
    {
        <section class="ai-output-panel" aria-label="AI output">
            <div class="ai-output-header">
                <h3>AI explanation</h3>
                <button class="button button-secondary" type="button" data-copy-target="operation-ai-output">Copy</button>
            </div>
            <pre id="operation-ai-output" class="code-block">@Model.AiOutput</pre>
        </section>
    }

    <h2>Parameters</h2>
    if (Model.Operation.Parameters.Count == 0)
    {
        <partial name="Shared/_EmptyState" model='new EmptyStateModel("No parameters defined.")' />
    }
    else
    {
        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">In</th>
                        <th scope="col">Required</th>
                        <th scope="col">Schema</th>
                        <th scope="col">Description</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var parameter in Model.Operation.Parameters)
                    {
                        <tr>
                            <td>@parameter.Name</td>
                            <td>@parameter.In</td>
                            <td>@(parameter.Required ? "Yes" : "No")</td>
                            <td>@FormatSchema(parameter.Schema)</td>
                            <td>@parameter.Description</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <h2>Responses</h2>
    if (Model.Operation.Responses.Count == 0)
    {
        <partial name="Shared/_EmptyState" model='new EmptyStateModel("No responses defined.")' />
    }
    else
    {
        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th scope="col">Status</th>
                        <th scope="col">Description</th>
                        <th scope="col">Content Types</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var response in Model.Operation.Responses.OrderBy(x => x.Key, StringComparer.Ordinal))
                    {
                        <tr>
                            <td>@response.Key</td>
                            <td>@response.Value.Description</td>
                            <td>@string.Join(", ", response.Value.Content.Keys)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@section Scripts {
    <script>
        document.querySelectorAll('[data-copy-target]').forEach(function (button) {
            button.addEventListener('click', async function () {
                var targetId = button.getAttribute('data-copy-target');
                var target = document.getElementById(targetId);
                if (!target) {
                    return;
                }

                try {
                    await navigator.clipboard.writeText(target.textContent || '');
                    button.textContent = 'Copied';
                    setTimeout(function () { button.textContent = 'Copy'; }, 1200);
                } catch {
                    button.textContent = 'Copy failed';
                    setTimeout(function () { button.textContent = 'Copy'; }, 1200);
                }
            });
        });
    </script>
}

@functions {
    private static string FormatSchema(ApiTester.Ui.Clients.OpenApiSchemaDto? schema)
    {
        if (schema is null)
        {
            return "n/a";
        }

        var nullable = schema.Nullable ? "?" : string.Empty;
        var format = string.IsNullOrWhiteSpace(schema.Format) ? string.Empty : $" ({schema.Format})";
        var items = schema.Items is null ? string.Empty : $" [{schema.Items.Type}{(string.IsNullOrWhiteSpace(schema.Items.Format) ? string.Empty : $" ({schema.Items.Format})")}]";
        return $"{schema.Type}{nullable}{format}{items}";
    }
}
