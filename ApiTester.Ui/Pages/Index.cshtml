@page
@model ApiTester.Ui.Pages.IndexModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Projects</title>
    <style>
        body {
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            margin: 2rem;
            color: #1f2933;
        }

        h1 {
            margin-bottom: 1rem;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1rem;
        }

        th, td {
            text-align: left;
            padding: 0.75rem 0.5rem;
            border-bottom: 1px solid #e5e7eb;
        }

        th {
            font-weight: 600;
            color: #374151;
        }

        .empty-state,
        .error-state {
            margin-top: 1rem;
            padding: 1rem;
            background: #f9fafb;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
        }

        details {
            margin-top: 0.5rem;
        }

        pre {
            margin: 0.5rem 0 0;
            white-space: pre-wrap;
            word-break: break-word;
            font-family: ui-monospace, "SFMono-Regular", Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
            font-size: 0.9rem;
        }

        a {
            color: #2563eb;
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <h1>Projects</h1>

    @if (Model.HasError)
    {
        <div class="error-state">
            <p>@Model.ErrorMessage</p>
            <details>
                <summary>Details</summary>
                <pre>@Model.ErrorDetails</pre>
            </details>
        </div>
    }
    else if (Model.Projects.Count == 0)
    {
        <div class="empty-state">
            <p>No projects yet, create one by running the client or API.</p>
        </div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>CreatedUtc</th>
                    <th>ProjectId</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var project in Model.Projects)
                {
                    <tr>
                        <td>
                            <a href="/projects/@project.ProjectId">@project.Name</a>
                        </td>
                        <td>@project.CreatedUtc.ToString("u")</td>
                        <td>@project.ProjectId</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</body>
</html>
