{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Persistence": {
    "Provider": "File"
  },
  "Auth": {
    "ApiKeys": [
      "dummyfull.aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
      "dev-local-key",
      "dev-secondary-key"
    ]
  },
  "Entitlements": {
    "Tier": "Free"
  },
  "AI": {
    "OpenAI": {
      "BaseUrl": "https://api.openai.com/v1",
      "DefaultModel": "gpt-4o-mini",
      "ProModel": "gpt-4o",
      "TimeoutSeconds": 30,
      "MaxRetries": 2,
      "CircuitBreakerFailureThreshold": 5,
      "CircuitBreakerBreakSeconds": 60,
      "MaxInputChars": 24000,
      "MaxOutputChars": 8000,
      "MaxResponseBytes": 64000
    }
  },
  "AllowedHosts": "*"
}
