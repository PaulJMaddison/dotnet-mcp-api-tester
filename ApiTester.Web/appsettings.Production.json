{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Persistence": {
    "Provider": "SqlServer",
    "ConnectionString": ""
  },
  "Auth": {
    "ApiKeys": []
  },
  "Entitlements": {
    "Tier": "Pro"
  },
  "AI": {
    "OpenAI": {
      "BaseUrl": "https://api.openai.com/v1",
      "ApiKey": "",
      "DefaultModel": "gpt-4o-mini",
      "ProModel": "gpt-4o"
    }
  },
  "CleanupJobs": {
    "Enabled": true,
    "RetentionIntervalMinutes": 60,
    "SnippetTrimIntervalMinutes": 120,
    "ResponseSnippetMaxChars": 4096,
    "StartupDelaySeconds": 30
  },
  "AllowedHosts": "*",
  "Security": {
    "HostedMode": false
  }
}
