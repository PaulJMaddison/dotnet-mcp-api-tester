{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Persistence": {
    "Provider": "SqlServer",
    "ConnectionString": ""
  },
  "Entitlements": {
    "Tier": "Pro"
  },
  "AbuseProtection": {
    "RateLimits": {
      "Default": {
        "Capacity": 120,
        "RefillTokensPerMinute": 120
      },
      "RunExecution": {
        "Capacity": 30,
        "RefillTokensPerMinute": 30
      },
      "Ai": {
        "Capacity": 10,
        "RefillTokensPerMinute": 10
      }
    }
  },
  "Security": {
    "HostedMode": false
  }
}
