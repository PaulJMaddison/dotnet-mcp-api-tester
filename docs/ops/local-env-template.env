# Local development template (no secrets)
# Copy to .env and fill in local values.

ASPNETCORE_ENVIRONMENT=Development

# Local API key used by smoke/e2e scripts
DEV_API_KEY=dev-local-key

# Optional Stripe placeholders (keep blank locally if not using billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# Optional OIDC placeholders
OIDC_AUTHORITY=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Optional ports
WEB_HTTP_PORT=8080
SITE_HTTP_PORT=8081
FIXTURE_HTTP_PORT=8082
